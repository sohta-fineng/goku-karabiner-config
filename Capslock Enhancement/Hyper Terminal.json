{
    "description": "Hyper Terminal",
    "enabled": false,
    "manipulators": [
        {
            "description": "command + d = define",
            "from": {
                "key_code": "d",
                "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "d",
                    "modifiers": ["left_control", "left_command"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "d = ctrl-d (EOF)",
            "from": {
                "key_code": "d",
                "modifiers": { "mandatory": ["right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "d",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "command + z = F5 (vscode debug)",
            "from": {
                "key_code": "z",
                "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [{ "key_code": "f5" }],
            "type": "basic"
        },
        {
            "description": "z = ctrl-z",
            "from": {
                "key_code": "z",
                "modifiers": { "mandatory": ["right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "z",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "command + x = ctrl + F5 (vscode run)",
            "from": {
                "key_code": "x",
                "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "f5",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "x = ctrl-r",
            "from": {
                "key_code": "x",
                "modifiers": { "mandatory": ["right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "r",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "command + c = shift + F5 (vscode stop)",
            "from": {
                "key_code": "c",
                "modifiers": { "mandatory": ["left_command", "right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "f5",
                    "modifiers": ["left_shift"]
                }
