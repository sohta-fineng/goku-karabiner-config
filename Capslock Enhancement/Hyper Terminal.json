            "type": "basic"
        },
        {
            "description": "c = ctrl-c",
            "from": {
                "key_code": "c",
                "modifiers": { "mandatory": ["right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "c",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "v = ctrl-v",
            "from": {
                "key_code": "v",
                "modifiers": { "mandatory": ["right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "v",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "b = ctrl-b",
            "from": {
                "key_code": "b",
                "modifiers": { "mandatory": ["right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "b",
                    "modifiers": ["left_control"]
