                "key_code": "tab",
                "modifiers": { "mandatory": ["left_option", "right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "right_arrow",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
