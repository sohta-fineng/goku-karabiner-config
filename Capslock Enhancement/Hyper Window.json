{
    "description": "Hyper Window",
    "manipulators": [
        {
            "description": "shift + tab = alter tab",
            "from": {
                "key_code": "tab",
                "modifiers": { "mandatory": ["left_shift", "right_command", "right_control", "right_shift", "right_option"] }
            },
            "to": [
                {
                    "key_code": "tab",
                    "modifiers": ["left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "option + tab = alter desktop",
