{
 :simlayers {
  :delete-layer     {:key :delete_or_backspace}
  :semicolon-layer  {:key :semicolon}
 }
 :input-sources {:greek {:input_source_id "com.apple.keylayout.Greek"}}

 :main [
  {:des "Base - Modifier Substitutions"
   :rules [
    [:##fn            :left_control]
    [:##caps_lock     :!QWEright_shift nil {:alone :escape}]
    [:!QWER#Pescape   :caps_lock]
    [:##right_shift   :!Sreturn_or_enter]
    [:##right_option  "open 'raycast://extensions/raycast/emoji-symbols/search-emoji-symbols'"]
    [:!!QWERspacebar  :spacebar] 
    [:##spacebar      :left_shift    nil {:alone :spacebar}]
   ]}

  {:des "Base - Input Source Switching"
   :rules [
    [:##left_command  :left_command  nil {:alone :japanese_eisuu}]
    [:##right_command :right_command nil {:alone :japanese_kana}]
    [:left_option     :left_option   nil {:alone :greek}]
   ]}

  {:des "Application - Hyper Launchers & Controls"
   :rules [
    ;; --- c / d ---
    [:!QWERCc         "open 'raycast://extensions/raycast/raycast-notes/raycast-notes'"]
    [:!QWERd          "open -a Obsidian"]
    [:!QWERCd         "open -a Bear"]
    [:!QWEROd         "open -a Logseq"]
    [:!QWERSd         "open -a Notion"]

    ;; --- e ---
    [:!QWERe          "open -a Arc"]
    [:!QWERCe         "open -a 'Google Chrome'"]
    [:!QWEROe         "open -a Safari"]
    [:!QWERSe         "open -a Cursor"]
    [:!QWERSCe        "open -a 'Visual Studio Code'"]
    [:!QWERSOe        "open -a Notes"]

    ;; --- f / g ---
    [:!QWERf          "open -a Raycast"]
    [:!QWERCf         "open -a 'Karabiner-Elements'"]
    [:!QWEROf         "open -a 'Karabiner-EventViewer'"]
    [:!QWERSf         "open -a 'Maccy'"]
    [:!QWERg          "open -a Claude"]
    [:!QWERCg         "open -a ChatGPT"]
    [:!QWEROg         "open -a Gemini"]
    [:!QWERSg         "open -a Ollama"]
    [:!QWERSCg        "open -a 'LM Studio'"]

    ;; --- r / t / y / x ---
    [:!QWERr          "open -a Finder"]
    [:!QWERCr         "open -a Preview"]
    [:!QWERSr         "open -a iTerm"]
    [:!QWERSCr        "open -a Terminal"]
    [:!QWERt          "open -a Slack"]
    [:!QWERCt         "open -a Discord"]
    [:!QWERy          "open -a Reminders"]
    [:!QWERCy         "open -a Mail"]
    [:!QWEROy         "open -a Calendar"]
    [:!QWERSx         "open 'raycast://extensions/mooxl/deepcast/index'"]
    [:!QWERCx         "open 'raycast://extensions/mooxl/deepcast/englishUS?arguments=%7B%22text%22%3A%22%22%7D'"]
    [:!QWEROx         "open 'raycast://extensions/mooxl/deepcast/japanese?arguments=%7B%22text%22%3A%22%22%7D'"]
   ]}

  {:des "Navigation - Hyper Mouse, Cursor & Window Actions"
   :rules [
    ;; --- a / s ---
    [:!QWERa          :!Copen_bracket]
    [:!QWERCa         :!Ttab]
    [:!QWEROa         :!OTbackslash]
    [:!QWERSa         :!Ctab]
    [:!QWERTa         :!Tleft_arrow]
    [:!QWERs          :!Cclose_bracket]
    [:!QWERCs         :!STtab]
    [:!QWEROs         :!SOTbackslash]
    [:!QWERSs         :!CStab]
    [:!QWERTs         :!Tright_arrow]

    ;; --- h ---
    [:!QWERh          :left_arrow]
    [:!QWERCh         :!Sleft_arrow]
    [:!QWEROCh        :!SOleft_arrow]
    [:!QWEROh         {:mouse_key {:x -1600}}]
    [:!QWERSOh        {:mouse_key {:x -3200}}]
    [:!QWERSCh        {:mouse_key {:horizontal_wheel 128}}]
    [:!QWERSTh        {:mouse_key {:horizontal_wheel 64}}]

    ;; --- j ---
    [:!QWERj          :down_arrow]
    [:!QWERCj         :!Sdown_arrow]
    [:!QWEROCj        [[:!Sdown_arrow] [:!Sdown_arrow] [:!Sdown_arrow]]]
    [:!QWEROj         {:mouse_key {:y 1600}}]
    [:!QWERSOj        {:mouse_key {:y 3200}}]
    [:!QWERSCj        {:mouse_key {:vertical_wheel 128}}]
    [:!QWERSTj        {:mouse_key {:vertical_wheel 64}}]

    ;; --- k ---
    [:!QWERk          :up_arrow]
    [:!QWERCk         :!Sup_arrow]
    [:!QWEROCk        [[:!Sup_arrow] [:!Sup_arrow] [:!Sup_arrow]]]
    [:!QWEROk         {:mouse_key {:y -1600}}]
    [:!QWERSOk        {:mouse_key {:y -3200}}]
    [:!QWERSCk        {:mouse_key {:vertical_wheel -128}}]
    [:!QWERSTk        {:mouse_key {:vertical_wheel -64}}]

    ;; --- l ---
    [:!QWERl          :right_arrow]
    [:!QWERCl         :!Sright_arrow]
    [:!QWEROCl        :!SOright_arrow]
    [:!QWEROl         {:mouse_key {:x 1600}}]
    [:!QWERSOl        {:mouse_key {:x 3200}}]
    [:!QWERSCl        {:mouse_key {:horizontal_wheel -128}}]
    [:!QWERSTl        {:mouse_key {:horizontal_wheel -64}}]

    ;; --- u ---
    [:!QWERu          :page_up]
    [:!QWERCu         :!Spage_up]
    [:!QWEROCu        :!Spage_up]
    [:!QWEROu         [[:pointing_button] [:button1]]]
    [:!QWERSOu        [[:pointing_button] [:button1]]]
    [:!QWERSCu        {:mouse_key {:horizontal_wheel -128}}]
    [:!QWERSTu        {:mouse_key {:horizontal_wheel -64}}]

    ;; --- i ---
    [:!QWERi          :home]
    [:!QWERCi         :!Shome]
    [:!QWEROCi        [[:end] [:!Shome] [:!Shome]]]
    [:!QWEROi         [[:pointing_button] [:button2]]]
    [:!QWERSOi        [[:pointing_button] [:button2]]]
    [:!QWERSCi        {:mouse_key {:vertical_wheel -128}}]
    [:!QWERSTi        {:mouse_key {:vertical_wheel -64}}]

    ;; --- o ---
    [:!QWERo          :end]
    [:!QWERCo         :!Send]
    [:!QWEROCo        [[:home] [:!Send]]]
    [:!QWEROo         [[:pointing_button] [:button4]]]
    [:!QWERSOo        [[:pointing_button] [:button4]]]
    [:!QWERSCo        {:mouse_key {:vertical_wheel 128}}]
    [:!QWERSTo        {:mouse_key {:vertical_wheel 64}}]

    ;; --- p ---
    [:!QWERp          :page_down]
    [:!QWERCp         :!Spage_down]
    [:!QWEROCp        :!Spage_down]
    [:!QWEROp         [[:pointing_button] [:button5]]]
    [:!QWERSOp        [[:pointing_button] [:button5]]]
    [:!QWERTp         "open -a 'Launchpad'"]
    [:!QWERSCp        {:mouse_key {:horizontal_wheel 128}}]

    ;; --- q / w ---
    [:!QWERq          :!Cq]
    [:!QWERSq         "osascript -e 'tell app \"System Events\" to restart'"]
    [:!QWERSCq        "osascript -e 'tell app \"System Events\" to shut down'"]
    [:!QWERSOq        :!CSq]
    [:!QWERw          :!Cw]
    [:!QWERCw         :!CSt]
    [:!QWERSw         :!CTq]
    [:!QWERSCw        "pmset sleepnow"]

    ;; --- z / x / c / v (Shortcuts) ---
    [:!QWERz          :!Cz]
    [:!QWERCz         :!CSz]
    [:!QWERx          :!Cx]
    [:!QWERc          :!Cc]
    [:!QWERv          :!Cv]

    ;; --- tab ---
    [:!QWERtab        "open -g 'raycast://extensions/raycast/window-management/maximize'"]
    [:!QWERCtab       :!CTf]
    [:!QWEROtab       :!Ch]
    [:!QWERStab       :launchpad]
    [:!QWERSCtab      :!Tup_arrow]
    [:!QWERSOtab      :!Tdown_arrow]
   ]}

  {:des "Editing - Hyper Deletion & Word Movement"
   :rules [
    ;; --- n ---
    [:!QWERn          :!Odelete_or_backspace]
    [:!QWERCn         [:!CSleft_arrow :delete_or_backspace]]
    [:!QWEROn         :!Cdelete_or_backspace]

    ;; --- m ---
    [:!QWERm          :delete_or_backspace]
    [:!QWERCm         [:delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace]]
    [:!QWEROm         :!OSdown_arrow]

    ;; --- comma ---
    [:!QWERcomma      :delete_forward]
    [:!QWERCcomma     [:delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward]]
    [:!QWEROcomma     :!OSup_arrow]

    ;; --- period ---
    [:!QWERperiod     :!Odelete_forward]
    [:!QWERCperiod    [:!CSright_arrow :delete_or_backspace]]
    [:!QWEROperiod    :!Cdelete_or_backspace]
   ]}

  {:des "Numpad - Hyper Layer"
   :rules [
    [:!QWERSn   :0]
    [:!QWERSj   :1]
    [:!QWERSk   :2]
    [:!QWERSl   :3]
    [:!QWERSu   :4]
    [:!QWERSi   :5]
    [:!QWERSo   :6]
    [:!QWERS7   :7]
    [:!QWERS8   :8]
    [:!QWERS9   :9]
    [:!QWERm    :delete_or_backspace]
   ]}

  {:des "Numpad - Semicolon Layer"
   :rules [
    [:n   :0                     :semicolon-layer]
    [:j   :1                     :semicolon-layer]
    [:k   :2                     :semicolon-layer]
    [:l   :3                     :semicolon-layer]
    [:u   :4                     :semicolon-layer]
    [:i   :5                     :semicolon-layer]
    [:o   :6                     :semicolon-layer]
    [:7   :7                     :semicolon-layer]
    [:8   :8                     :semicolon-layer]
    [:9   :9                     :semicolon-layer]
    [:m   :delete_or_backspace   :semicolon-layer]
   ]}

  {:des "Functional - F1-F12 & Hyphen/Equal Controls"
   :rules [
    [:!QWERChyphen       :!Chyphen]
    [:!QWERCequal_sign   :!Cequal_sign]
    [:!QWEROhyphen       :!COhyphen]
    [:!QWEROequal_sign   :!COequal_sign]

    [:!QWER1               :f1]
    [:!QWER2               :f2]
    [:!QWER3               :f3]
    [:!QWER4               :f4]
    [:!QWER5               :f5]
    [:!QWER6               :f6]
    [:!QWER7               :f7]
    [:!QWER8               :f8]
    [:!QWER9               :f9]
    [:!QWER0               :f10]
    [:!QWERhyphen          :f11]
    [:!QWERequal_sign      :f12]
   ]}

  {:des "Functional - Delete Layer Media Keys"
   :rules [
    [:f7              :rewind           :delete-layer]
    [:f8              :play_or_pause    :delete-layer]
    [:f9              :fast_forward     :delete-layer]
    [:f10             :mute             :delete-layer]
    [:f11             :volume_decrement :delete-layer]
    [:f12             :volume_increment :delete-layer]
   ]}

  {:des "Functional - Hyper Media Controls"
   :rules [
    [:!QWERf1         :display_brightness_decrement]
    [:!QWERf2         :display_brightness_increment]
    [:!QWERf3         :!Tup_arrow]
    [:!QWERf4         :launchpad]
    [:!QWERf5         :illumination_decrement]
    [:!QWERf6         :illumination_increment]
    [:!QWERf7         :rewind]
    [:!QWERf8         :play_or_pause]
    [:!QWERf9         :fast_forward]
    [:!QWERf10        :mute]
    [:!QWERf11        :volume_decrement]
    [:!QWERf12        :volume_increment]
   ]}

  {:des "Functional - Hyper Screen Capture"
   :rules [
    [:!QWERCgrave_accent_and_tilde :!CS4]
    [:!QWERgrave_accent_and_tilde  :!CTS4]

    [:!QWERCf13       :!CS3]
    [:!QWERf13        :!CTS3]

    [:!QWERCf14       :!CS6]
    [:!QWERf14        :!CS5]
    [:!QWERf15        :play_or_pause]
   ]}

  {:des "Functional - Hyper Precision Hardware Controls"
   :rules [
    ;; 以下のキーマップは、macOSのデフォルト（Opt + Shift + 輝度/音量）による「1/4目盛り単位」の微調整を再現しています
    [:!QWERinsert         :!OSdisplay_brightness_increment]
    [:!QWERdelete_forward :!OSdisplay_brightness_decrement]
    [:!QWERhome           :!OSillumination_increment]
    [:!QWERend            :!OSillumination_decrement]
    [:!QWERpage_up        :!OSvolume_increment]
    [:!QWERpage_down      :!OSvolume_decrement]
   ]}

  {:des "Text - Hyper Returns & Symbols"
   :rules [
    [:!QWERSp              :grave_accent_and_tilde]

    [:!QWERopen_bracket   :!S9]
    [:!QWERSopen_bracket  :!Sopen_bracket]
    [:!QWERCopen_bracket  :!Scomma]
    [:!QWEROopen_bracket  :hyphen]
    [:!QWERTopen_bracket  :!Shyphen]

    [:!QWERclose_bracket  :!S9]
    [:!QWERSclose_bracket :!Sclose_bracket]
    [:!QWERCclose_bracket :!Speriod]
    [:!QWEROclose_bracket :equal_sign]
    [:!QWERTclose_bracket :!Sequal_sign]

    [:!QWERsemicolon      :return_or_enter]
    [:!QWERSsemicolon     :!Ssemicolon]
    [:!QWERCsemicolon     :!Creturn_or_enter]
    [:!QWEROsemicolon     :!Oreturn_or_enter]
    [:!QWERTsemicolon     :!Treturn_or_enter]

    [:!QWERquote          :return_or_enter]
    [:!QWERSquote         :!Squote]
    [:!QWERCquote         :!Creturn_or_enter]
    [:!QWEROquote         :!Oreturn_or_enter]
    [:!QWERTquote         :!Treturn_or_enter]

    [:!QWERslash          :!Cslash]
    [:!QWERCslash         :!S1]
    [:!QWEROslash         :!S3]
    [:!QWERTslash         :!S4]
    [:!QWERSslash         :!Sslash]
    [:!QWERSCslash        :!S8]
    [:!QWERSOslash        :!S7]
    [:!QWERSTslash        :!S6]
   ]}

  {:des "Application - Raycast Window Management"
   :rules [
    [:!QWERCTh        ["open -g 'raycast://extensions/raycast/window-management/left-half'"]]
    [:!QWERCTl        ["open -g 'raycast://extensions/raycast/window-management/right-half'"]]
    [:!QWERCTk        ["open -g 'raycast://extensions/raycast/window-management/top-half'"]]
    [:!QWERCTj        ["open -g 'raycast://extensions/raycast/window-management/bottom-half'"]]
    [:!QWERCTu        ["open -g 'raycast://extensions/raycast/window-management/almost-maximize'"]]
    [:!QWERCTi        ["open -g 'raycast://extensions/raycast/window-management/make-larger'"]]
    [:!QWERCTo        ["open -g 'raycast://extensions/raycast/window-management/make-smaller'"]]
    [:!QWERCTp        ["open -g 'raycast://extensions/raycast/window-management/reasonable-size'"]]
   ]}
 ]
}