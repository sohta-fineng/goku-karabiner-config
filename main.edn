;; ===================================================================================
;;  SCOT Matrix Layout
;;  - Hyper-key spatial layer mapping for navigation, mouse, and window actions.
;; ===================================================================================
;;
;;  Hyper + | None         | S (Shift)    | C (Command)  | O (Option)   | T (Control)
;;  --------+--------------+--------------+--------------+--------------+--------------
;;    None  | Nav & Delete | Numpad Input | Select & Del | Mouse Normal | Mouse Fast
;;     +S   | --           | --           | Symbol Num   | Wheel Scroll | Fn Key Input
;;     +C   | --           | --           | --           | Smart Select | Win Resize
;;     +O   | --           | --           | --           | --           | Win Move
;;
;;  [Legend]
;;  ! : Mandatory  | # : Optional  | ## : Optional Any  | P : CapsLock
;;
;;  C : L_Command  | T : L_Control | O  : L_Option      | S : L_Shift
;;  Q : R_Command  | W : R_Control | E  : R_Option      | R : R_Shift
;;  (* !QWER = Hyper Layer Activation)
;;
;; ===================================================================================

{
 :simlayers {
  :delete-layer     {:key :delete_or_backspace}
  :semicolon-layer  {:key :semicolon}
 }
 
 :templates {
  :clip-save "pbpaste > ~/.clip%s"
  :clip-load "cat ~/.clip%s | pbcopy"
  :app       "open -a '%s'"
  :ray       "open -g 'raycast://extensions/%s'"
  :wm        "open -g 'raycast://extensions/raycast/window-management/%s'"
  :sys-evt   "osascript -e 'tell app "System Events" to %s'"
  :pwr       "pmset %s"
 }

 :input-sources {:greek {:input_source_id "com.apple.keylayout.Greek"}}

 :main [
  ;; =================================================================================
  ;;  1. SYSTEM & BASE MODIFIERS (システム & 基本モディファイア)
  ;; =================================================================================
  {:des "System - Base Modifier Substitutions"
   :rules [
    [:##caps_lock     :!QWEright_shift nil {:alone :escape}]
    [:!QWER#Pescape   :caps_lock]
    [:##spacebar      :left_shift nil {:alone :spacebar}]
    [:!QWERspacebar   :spacebar]
    [:##fn            :left_control]
    [:##right_shift   :!Sreturn_or_enter]
    [:##right_option  [:ray "raycast/emoji-symbols/search-emoji-symbols"]]
   ]}

  {:des "System - Input Source Switching"
   :rules [
    [:##left_command  :left_command nil {:alone :japanese_eisuu}]
    [:##right_command :right_command nil {:alone :japanese_kana}]
    [:left_option     :left_option   nil {:alone :greek}]
   ]}

  ;; =================================================================================
  ;;  2. APPLICATION LAUNCHERS (アプリケーション・ランチャー)
  ;; =================================================================================
  {:des "App - Hyper Launchers & Power Controls"
   :rules [
    ;; e / r / t / y (Row 1)
    [:!QWERe          [:app "Arc"]]
    [:!QWERCe         [:app "Google Chrome"]]
    [:!QWEROe         [:app "Safari"]]
    [:!QWERSe         [:app "Cursor"]]
    [:!QWERSCe        [:app "Visual Studio Code"]]
    [:!QWERSOe        [:app "Notes"]]
    [:!QWERr          [:app "Finder"]]
    [:!QWERCr         [:app "Preview"]]
    [:!QWERSr         [:app "iTerm"]]
    [:!QWERSCr        [:app "Terminal"]]
    [:!QWERt          [:app "Slack"]]
    [:!QWERCt         [:app "Discord"]]
    [:!QWERy          [:app "Reminders"]]
    [:!QWERCy         [:app "Mail"]]
    [:!QWEROy         [:app "Calendar"]]

    ;; d / f / g (Row 2)
    [:!QWERd          [:app "Obsidian"]]
    [:!QWERCd         [:app "Bear"]]
    [:!QWEROd         [:app "Logseq"]]
    [:!QWERSd         [:app "Notion"]]
    [:!QWERf          [:app "Raycast"]]
    [:!QWERCf         [:app "Karabiner-Elements"]]
    [:!QWEROf         [:app "Karabiner-EventViewer"]]
    [:!QWERSf         [:app "Maccy"]]
    [:!QWERg          [:app "Claude"]]
    [:!QWERCg         [:app "ChatGPT"]]
    [:!QWEROg         [:app "Gemini"]]
    [:!QWERSg         [:app "Ollama"]]
    [:!QWERSCg        [:app "LM Studio"]]
   ]}

  {:des "App - AI Tools & Translation"
   :rules [
    ;; x / c (Row 3)
    [:!QWERSx         [:ray "mooxl/deepcast/index"]]
    [:!QWERCx         "open 'raycast://extensions/mooxl/deepcast/englishUS?arguments=%7B%22text%22%3A%22%22%7D'"]
    [:!QWEROx         "open 'raycast://extensions/mooxl/deepcast/japanese?arguments=%7B%22text%22%3A%22%22%7D'"]
    [:!QWERSc         "open 'raycast://extensions/raycast/raycast-notes/raycast-notes'"]
   ]}

  ;; =================================================================================
  ;;  3. NAVIGATION & WORKSPACE CONTROL (ナビゲーション & ウィンドウ管理)
  ;; =================================================================================
{:des "Workspace - Left-side Nav & Power Controls"
 :rules [
  ;; q / w / a / s (Left-side Cluster)
  [:!QWERq          :!Cq]
  [:!QWERCq         :!Ch]
  [:!QWERSq         [:sys-evt "restart"]]
  [:!QWERSCq        [:sys-evt "shut down"]]
  [:!QWERSOq        :!SCq]
  [:!QWERw          :!Cw]
  [:!QWERCw         :!SCt]
  [:!QWERSw         :!CTq]
  [:!QWERSCw        [:pwr "sleepnow"]]
  [:!QWERSOw        [:pwr "displaysleepnow"]]
  [:!QWERa          :!Copen_bracket]
  [:!QWERCa         :!STtab]
  [:!QWEROa         :!SOTbackslash]
  [:!QWERSa         :!SCtab]
  [:!QWERTa         :!Tright_arrow]
  [:!QWERs          :!Cclose_bracket]
  [:!QWERCs         :!Ttab]
  [:!QWEROs         :!OTbackslash]
  [:!QWERSs         :!Ctab]
  [:!QWERTs         :!Tleft_arrow]
 ]}

  {:des "Workspace - Vim Navigation & Mouse Actions"
   :rules [
    ;; u / i / o / p (Page Nav / Mouse Buttons)
    [:!QWERu          :page_up]
    [:!QWERCu         :!Spage_up]
    [:!QWERCOu        :!Oup_arrow]
    [:!QWEROu         {:pkey :button1}]
    [:!QWERTu         {:pkey :button1}]
    [:!QWERSOu        {:mkey {:hwheel -128}}]
    [:!QWERi          :home]
    [:!QWERCi         :!Shome]
    [:!QWERCOi        :!SOup_arrow]
    [:!QWEROi         {:pkey :button2}]
    [:!QWERTi         {:pkey :button2}]
    [:!QWERSOi        {:mkey {:vwheel -128}}]
    [:!QWERo          :end]
    [:!QWERCo         :!Send]
    [:!QWERCOo        :!SOdown_arrow]
    [:!QWEROo         {:pkey :button4}]
    [:!QWERTo         {:pkey :button4}]
    [:!QWERSOo        {:mkey {:vwheel 128}}]
    [:!QWERp          :page_down]
    [:!QWERCp         :!Spage_down]
    [:!QWERCOp        :!Odown_arrow]
    [:!QWEROp         {:pkey :button5}]
    [:!QWERTp         {:pkey :button5}]
    [:!QWERSOp        {:mkey {:hwheel 128}}]

    ;; h / j / k / l (Vim Navigation & Mouse Move)
    [:!QWERh          :left_arrow]
    [:!QWERCh         :!Sleft_arrow]
    [:!QWERCOh        :!SOleft_arrow]
    [:!QWEROh         {:mkey {:x -1600}}]
    [:!QWERTh         {:mkey {:x -3200}}]
    [:!QWERSOh        {:mkey {:hwheel 128}}]
    [:!QWERj          :down_arrow]
    [:!QWERCj         :!Sdown_arrow]
    [:!QWERCOj        [:!Sdown_arrow :!Sdown_arrow :!Sdown_arrow]]
    [:!QWEROj         {:mkey {:y 1600}}]
    [:!QWERTj         {:mkey {:y 3200}}]
    [:!QWERSOj        {:mkey {:vwheel 128}}]
    [:!QWERk          :up_arrow]
    [:!QWERCk         :!Sup_arrow]
    [:!QWERCOk        [:!Sup_arrow :!Sup_arrow :!Sup_arrow]]
    [:!QWEROk         {:mkey {:y -1600}}]
    [:!QWERTk         {:mkey {:y -3200}}]
    [:!QWERSOk        {:mkey {:vwheel -128}}]
    [:!QWERl          :right_arrow]
    [:!QWERCl         :!Sright_arrow]
    [:!QWERCOl        :!SOright_arrow]
    [:!QWEROl         {:mkey {:x 1600}}]
    [:!QWERTl         {:mkey {:x 3200}}]
    [:!QWERSOl        {:mkey {:hwheel -128}}]
   ]}

  {:des "Workspace - Raycast Window Management"
   :rules [
    ;; q / w / a / s (Sixths)
    [:!QWERCTq        [:wm "top-left-sixth"]]
    [:!QWERCTw        [:wm "top-right-sixth"]]
    [:!QWERCTa        [:wm "bottom-left-sixth"]]
    [:!QWERCTs        [:wm "bottom-right-sixth"]]

    ;; u / i / o / p (Size & Placement)
    [:!QWERCTu        [:wm "toggle-fullscreen"]]
    [:!QWEROTu        [:wm "toggle-fullscreen"]]
    [:!QWERCTi        [:wm "maximize"]]
    [:!QWEROTi        [:wm "maximize"]]
    [:!QWERCTo        [:wm "almost-maximize"]]
    [:!QWEROTo        [:wm "reasonable-size"]]
    [:!QWERCTp        [:wm "center"]]
    [:!QWEROTp        [:wm "center"]]

    ;; h / j / k / l (Halves & Movement)
    [:!QWERCTh        [:wm "left-half"]]
    [:!QWEROTh        [:wm "move-left"]]
    [:!QWERCTj        [:wm "make-smaller"]]
    [:!QWEROTj        [:wm "move-up"]]
    [:!QWERCTk        [:wm "make-larger"]]
    [:!QWEROTk        [:wm "move-down"]]
    [:!QWERCTl        [:wm "right-half"]]
    [:!QWEROTl        [:wm "move-right"]]
   ]}

  ;; =================================================================================
  ;;  4. TEXT EDITING & INPUT LAYERS (テキスト編集・入力レイヤー)
  ;; =================================================================================
  {:des "Text - Hyper Deletion & Word Movement"
   :rules [
    [:!QWERb          :!Odelete_or_backspace]
    [:!QWERCb         :!Cdelete_or_backspace]
    [:!QWERn          :delete_or_backspace]
    [:!QWERCn         [:!SCleft_arrow :delete_or_backspace]]
    [:!QWERm          :delete_forward]
    [:!QWERCm         [:!SCright_arrow :delete_or_backspace]]
    [:!QWERcomma      :!Odelete_forward]
    [:!QWERCcomma     :!Cdelete_forward]
   ]}

  {:des "Text - Hyper Returns & Symbols"
   :rules [
    ;; p / open_bracket / close_bracket / backslash
    [:!QWERSp             :!Cslash]
    [:!QWERSCp            :!Cslash]
    [:!QWERSOp            :!Cslash]
    [:!QWERopen_bracket   :!S9]
    [:!QWERSopen_bracket  :!Sopen_bracket]
    [:!QWERCopen_bracket  :!Scomma]
    [:!QWEROopen_bracket  :!S3]
    [:!QWERclose_bracket  :!S0]
    [:!QWERSclose_bracket :!Sclose_bracket]
    [:!QWERCclose_bracket :!Speriod]
    [:!QWEROclose_bracket :!S8]
    [:!QWERbackslash      :grave_accent_and_tilde]
    [:!QWERSbackslash     :!Sbackslash]
    [:!QWERObackslash     [:grave_accent_and_tilde :grave_accent_and_tilde :grave_accent_and_tilde]]
    [:!QWERCbackslash     :!Sgrave_accent_and_tilde]

    ;; semicolon / quote / period / slash
    [:!QWERsemicolon      :return_or_enter]
    [:!QWERSsemicolon     :!Ssemicolon]
    [:!QWERCsemicolon     :!Creturn_or_enter]
    [:!QWEROsemicolon     :!Oreturn_or_enter]
    [:!QWERTsemicolon     :!Treturn_or_enter]
    [:!QWERquote          :return_or_enter]
    [:!QWERSquote         :!Squote]
    [:!QWERCquote         :!Creturn_or_enter]
    [:!QWEROquote         :!Oreturn_or_enter]
    [:!QWERTquote         :!Treturn_or_enter]
    [:!QWERperiod         :equal_sign]
    [:!QWERCperiod        :!Sequal_sign]
    [:!QWERslash          :hyphen]
    [:!QWERSslash         :!Sslash]
    [:!QWERCslash         :!Shyphen]
   ]}

  {:des "Text - Numpad Layers (Hyper & Semicolon)"
   :rules [
    ;; Numpad - Hyper Layer
    [:!QWERSn         :0]
    [:!QWERSm         :1]
    [:!QWERScomma     :2]
    [:!QWERSperiod    :3]
    [:!QWERSj         :4]
    [:!QWERSk         :5]
    [:!QWERSl         :6]
    [:!QWERSu         :7]
    [:!QWERSi         :8]
    [:!QWERSo         :9]

    ;; Shift Numpad - Hyper Layer
    [:!QWERSCm        :!S1]
    [:!QWERSCcomma    :!S2]
    [:!QWERSCperiod   :!S3]
    [:!QWERSCj        :!S4]
    [:!QWERSCk        :!S5]
    [:!QWERSCl        :!S6]
    [:!QWERSCu        :!S7]
    [:!QWERSCi        :!S8]
    [:!QWERSCo        :!S9]

    ;; Numpad - Semicolon Layer
    [[:n       :semicolon]   :0]
    [[:m       :semicolon]   :1]
    [[:comma   :semicolon]   :2]
    [[:period  :semicolon]   :3]
    [[:j       :semicolon]   :4]
    [[:k       :semicolon]   :5]
    [[:l       :semicolon]   :6]
    [[:u       :semicolon]   :7]
    [[:i       :semicolon]   :8]
    [[:o       :semicolon]   :9]
    
    [:n                      :0   :semicolon-layer]
    [:m                      :1   :semicolon-layer]
    [:comma                  :2   :semicolon-layer]
    [:period                 :3   :semicolon-layer]
    [:j                      :4   :semicolon-layer]
    [:k                      :5   :semicolon-layer]
    [:l                      :6   :semicolon-layer]
    [:u                      :7   :semicolon-layer]
    [:i                      :8   :semicolon-layer]
    [:o                      :9   :semicolon-layer]
   ]}

  ;; =================================================================================
  ;;  5. HARDWARE, FUNCTION KEYS & CLIPBOARD (ハードウェア・機能キー & クリップボード)
  ;; =================================================================================
  {:des "Global - OS Shortcuts & Clipboard"
   :rules [
    ;; Basic edits that were mixed in row 3
    [:!QWERz          :!Cz]
    [:!QWERCz         :!SCz]
    [:!QWERx          :!Cx]
    [:!QWERc          :!Cc]
    [:!QWERCc         [:!Ca :!Cc]]
    [:!QWERv          :!Cv]

    ;; Save Clips (0-9 numerical order)
    [:!QWERC0 [:!Cc [:clip-save "0"]]]
    [:!QWERC1 [:!Cc [:clip-save "1"]]]
    [:!QWERC2 [:!Cc [:clip-save "2"]]]
    [:!QWERC3 [:!Cc [:clip-save "3"]]]
    [:!QWERC4 [:!Cc [:clip-save "4"]]]
    [:!QWERC5 [:!Cc [:clip-save "5"]]]
    [:!QWERC6 [:!Cc [:clip-save "6"]]]
    [:!QWERC7 [:!Cc [:clip-save "7"]]]
    [:!QWERC8 [:!Cc [:clip-save "8"]]]
    [:!QWERC9 [:!Cc [:clip-save "9"]]]

    ;; Load Clips (0-9 numerical order)
    [:!QWER0 [[:clip-load "0"] :!Cv]]
    [:!QWER1 [[:clip-load "1"] :!Cv]]
    [:!QWER2 [[:clip-load "2"] :!Cv]]
    [:!QWER3 [[:clip-load "3"] :!Cv]]
    [:!QWER4 [[:clip-load "4"] :!Cv]]
    [:!QWER5 [[:clip-load "5"] :!Cv]]
    [:!QWER6 [[:clip-load "6"] :!Cv]]
    [:!QWER7 [[:clip-load "7"] :!Cv]]
    [:!QWER8 [[:clip-load "8"] :!Cv]]
    [:!QWER9 [[:clip-load "9"] :!Cv]]
   ]}

  {:des "Global - Hardware & Media Controls"
   :rules [
    [:!QWERtab        :f6]
    [:!QWERCtab       :!Sf6]
    [:!QWEROtab       :!Tf2]
    [:!QWERStab       :launchpad]
    [:!QWERhyphen       :!Chyphen]
    [:!QWERChyphen      :!COhyphen]
    [:!QWERequal_sign   :!Cequal_sign]
    [:!QWERCequal_sign  :!COequal_sign]

    [:!QWERf1         :display_brightness_decrement]
    [:!QWERf2         :display_brightness_increment]
    [:!QWERf3         :!Tup_arrow]
    [:!QWERf4         :launchpad]
    [:!QWERf5         :illumination_decrement]
    [:!QWERf6         :illumination_increment]
    [:!QWERf7         :rewind]
    [:!QWERf8         :play_or_pause]
    [:!QWERf9         :fast_forward]
    [:!QWERf10        :mute]
    [:!QWERf11        :volume_decrement]
    [:!QWERf12        :volume_increment]

    ;; Functional - Delete Layer Media Keys
    [:f7              :rewind           :delete-layer]
    [:f8              :play_or_pause    :delete-layer]
    [:f9              :fast_forward     :delete-layer]
    [:f10             :mute             :delete-layer]
    [:f11             :volume_decrement :delete-layer]
    [:f12             :volume_increment :delete-layer]
   ]}

  {:des "Global - Screen Capture & Function Keys"
   :rules [
    ;; Screen Capture
    [:!QWERgrave_accent_and_tilde  :!SCT4]
    [:!QWERCgrave_accent_and_tilde :!SC4]

    ;; Function Keys
    [:!QWERSTb        :f1]
    [:!QWERSTn        :f2]
    [:!QWERSTm        :f3]
    [:!QWERSTcomma    :f4]
    [:!QWERSTh        :f5]
    [:!QWERSTj        :f6]
    [:!QWERSTk        :f7]
    [:!QWERSTl        :f8]
    [:!QWERSTu        :f9]
    [:!QWERSTi        :f10]
    [:!QWERSTo        :f11]
    [:!QWERSTp        :f12]
   ]}
 ]
}