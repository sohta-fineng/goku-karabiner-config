{
 :simlayers {
  :delete-layer     {:key :delete_or_backspace}
  :semicolon-layer  {:key :semicolon}
 }
 :input-sources {:greek {:input_source_id "com.apple.keylayout.Greek"}}

 :main [
  {:des "Replace Modifier Keys"
   :rules [
    [:##fn            :left_control]
    [:##caps_lock     :!QWEright_shift nil {:alone :escape}]
    [:!QWER#Pescape   :caps_lock]
    [:##right_shift   :!Sreturn_or_enter]
    [:##right_option  "open 'raycast://extensions/raycast/emoji-symbols/search-emoji-symbols'"]
    [:!!QWERspacebar  :spacebar] 
   ]}

  {:des "Fn Number"
   :rules [
    [:!QWERChyphen       :!Chyphen]
    [:!QWERCequal_sign   :!Cequal_sign]
    [:!QWEROhyphen       :!COhyphen]
    [:!QWEROequal_sign   :!COequal_sign]

    [:!QWER1               :f1]
    [:!QWER2               :f2]
    [:!QWER3               :f3]
    [:!QWER4               :f4]
    [:!QWER5               :f5]
    [:!QWER6               :f6]
    [:!QWER7               :f7]
    [:!QWER8               :f8]
    [:!QWER9               :f9]
    [:!QWER0               :f10]
    [:!QWERhyphen          :f11]
    [:!QWERequal_sign      :f12]
   ]}

 {:des "Hyper NumPad"
   :rules [
    [:!QWERSj   :1]
    [:!QWERSk   :2]
    [:!QWERSl   :3]
    [:!QWERSu   :4]
    [:!QWERSi   :5]
    [:!QWERSo   :6]
    [:!QWERS7   :7]
    [:!QWERS8   :8]
    [:!QWERS9   :9]
    [:!QWERSn   :0]
    [:!QWERm    :delete_or_backspace]
   ]}

  {:des "Semicolon NumPad"
   :rules [
    [:j   :1   :semicolon-layer]
    [:k   :2   :semicolon-layer]
    [:l   :3   :semicolon-layer]
    [:u   :4   :semicolon-layer]
    [:i   :5   :semicolon-layer]
    [:o   :6   :semicolon-layer]
    [:7   :7   :semicolon-layer]
    [:8   :8   :semicolon-layer]
    [:9   :9   :semicolon-layer]
    [:n   :0   :semicolon-layer]
    [:m   :delete_or_backspace   :semicolon-layer]
   ]}

  {:des "Command"
   :rules [
    [:!QWERz   :!Cz]
    [:!QWERCz  :!CSz]
    [:!QWERx   :!Cx]
    [:!QWERc   :!Cc]
    [:!QWERv   :!Cv]
   ]}



  ;; =======================================================================
  ;; 基本修飾キー・レイヤー設定 [cite: 1]
  ;; =======================================================================
  {:des "SandS (Space and Shift)"
   :rules [
    [:##spacebar      :left_shift    nil {:alone :spacebar}]             ;; Space単押しでSpace、他キーとの同時押しで左Shift [cite: 2]
   ]}

  {:des "L-Command -> English / R-Command -> Japanese"
   :rules [
    [:##left_command  :left_command  nil {:alone :japanese_eisuu}]       ;; 左Cmd単押しで「英数」、同時押しで左Cmd [cite: 2]
    [:##right_command :right_command nil {:alone :japanese_kana}]        ;; 右Cmd単押しで「かな」、同時押しで右Cmd [cite: 2]
   ]}

  {:des "L-Option -> Greek"
   :rules [
    [:left_option     :left_option   nil {:alone :greek}]                ;; 左Opt単押しでギリシャ語キーボードへ切り替え [cite: 2]
   ]}

  {:des "Delete + F7-F12 for Media Keys"
   :rules [
    [:f7              :rewind           :delete-layer]                   ;; Delete + F7: 巻き戻し [cite: 3, 4]
    [:f8              :play_or_pause    :delete-layer]                   ;; Delete + F8: 再生 / 一時停止 [cite: 5]
    [:f9              :fast_forward     :delete-layer]                   ;; Delete + F9: 早送り [cite: 6]
    [:f10             :mute             :delete-layer]                   ;; Delete + F10: ミュート [cite: 7]
    [:f11             :volume_decrement :delete-layer]                   ;; Delete + F11: 音量を下げる [cite: 8]
    [:f12             :volume_increment :delete-layer]                   ;; Delete + F12: 音量を上げる [cite: 9]
   ]}

  ;; =======================================================================
  ;; アプリケーション起動・フォーカス (Hyper Application) [cite: 12]
  ;; =======================================================================
  {:des "Hyper Application (original)"
   :rules [
    ;; --- ブラウザ・エディタ系 --- [cite: 13]
    [:!QWERe          ["open -a Arc"]]                                   ;; Hyper + e: Arc ブラウザを起動 / 最前面へ [cite: 14]
    [:!QWERCe         ["open -a 'Google Chrome'"]]                       ;; Cmd + Hyper + e: Google Chrome を起動 / 最前面へ [cite: 15]
    [:!QWEROe         ["open -a Safari"]]                                ;; Opt + Hyper + e: Safari を起動 / 最前面へ [cite: 16]
    [:!QWERSe         ["open -a Cursor"]]                                ;; Shift + Hyper + e: Cursor を起動 / 最前面へ [cite: 17]
    [:!QWERSCe        ["open -a 'Visual Studio Code'"]]                  ;; Shift + Cmd + Hyper + e: VS Code を起動 / 最前面へ [cite: 18]
    [:!QWERSOe        ["open -a Notes"]]                                 ;; Shift + Opt + Hyper + e: メモ(Notes) を起動 / 最前面へ [cite: 19]

    ;; --- ユーティリティ・ターミナル系 --- [cite: 20]
    [:!QWERr          ["open -a Finder"]]                                ;; Hyper + r: Finder を起動 / 最前面へ [cite: 21]
    [:!QWERCr         ["open -a Preview"]]                               ;; Cmd + Hyper + r: プレビュー(Preview) を起動 / 最前面へ [cite: 22]
    [:!QWERSr         ["open -a iTerm"]]                                 ;; Shift + Hyper + r: iTerm を起動 / 最前面へ [cite: 23]
    [:!QWERSCr        ["open -a Terminal"]]                              ;; Shift + Cmd + Hyper + r: Terminal を起動 / 最前面へ [cite: 23]
    
    ;; --- 連絡ツール系 --- [cite: 24]
    [:!QWERt          ["open -a Slack"]]                                 ;; Hyper + t: Slack を起動 / 最前面へ [cite: 24]
    [:!QWERCt         ["open -a Discord"]]                               ;; Cmd + Hyper + t: Discord を起動 / 最前面へ [cite: 24]

    ;; --- PIM (スケジュール・タスク・メール) 系 --- [cite: 25]
    [:!QWERy          ["open -a Reminders"]]                             ;; Hyper + y: リマインダー を起動 / 最前面へ [cite: 26]
    [:!QWERCy         ["open -a Mail"]]                                  ;; Cmd + Hyper + y: メール(Mail) を起動 / 最前面へ [cite: 27]
    [:!QWEROy         ["open -a Calendar"]]                              ;; Opt + Hyper + y: カレンダー を起動 / 最前面へ [cite: 28]

    ;; --- ドキュメント・ノート系 --- [cite: 29]
    [:!QWERd          ["open -a Obsidian"]]                              ;; Hyper + d: Obsidian を起動 / 最前面へ [cite: 30]
    [:!QWERCd         ["open -a Bear"]]                                  ;; Cmd + Hyper + d: Bear を起動 / 最前面へ [cite: 31]
    [:!QWEROd         ["open -a Logseq"]]                                ;; Opt + Hyper + d: Logseq を起動 / 最前面へ [cite: 32]
    [:!QWERSd         ["open -a Notion"]]                                ;; Shift + Hyper + d: Notion を起動 / 最前面へ [cite: 33]

    ;; --- ツール・システム系 --- [cite: 34]
    [:!QWERf          ["open -a Raycast"]]                               ;; Hyper + f: Raycast を起動 / 最前面へ [cite: 35]
    [:!QWERCf         ["open -a 'Karabiner-Elements'"]]                  ;; Cmd + Hyper + f: Karabiner-Elements を起動 [cite: 36]
    [:!QWEROf         ["open -a 'Karabiner-EventViewer'"]]               ;; Opt + Hyper + f: Karabiner-EventViewer を起動 [cite: 37]
    [:!QWERSf         ["open -a 'Maccy'"]]                               ;; Shift + Hyper + f: クリップボード拡張(Maccy) を起動 [cite: 38]

    ;; --- AI系 --- [cite: 39]
    [:!QWERg          ["open -a Claude"]]                                ;; Hyper + g: Claude アプリを起動 / 最前面へ [cite: 40]
    [:!QWERCg         ["open -a ChatGPT"]]                               ;; Cmd + Hyper + g: ChatGPT アプリを起動 / 最前面へ [cite: 41]
    [:!QWEROg         ["open -a Gemini"]]                                ;; Opt + Hyper + g: Gemini アプリを起動 / 最前面へ [cite: 42]
    [:!QWERSg         ["open -a Ollama"]]                                ;; Shift + Hyper + g: Ollama アプリを起動 / 最前面へ [cite: 43]
    [:!QWERSCg        ["open -a 'LM Studio'"]]                           ;; Shift + Cmd + Hyper + g: LM Studio を起動 / 最前面へ [cite: 44]

    ;; --- Raycast拡張機能系 --- [cite: 45]
    [:!QWERSx          ["open 'raycast://extensions/mooxl/deepcast/index'"]]       ;; Hyper + x: Deepcast (翻訳) を開く [cite: 49]
    [:!QWERCx          ["open 'raycast://extensions/mooxl/deepcast/englishUS?arguments=%7B%22text%22%3A%22%22%7D'"]] ;; Cmd + Hyper + x: 英語(US)翻訳を実行 [cite: 50]
    [:!QWEROx          ["open 'raycast://extensions/mooxl/deepcast/japanese?arguments=%7B%22text%22%3A%22%22%7D'"]]  ;; Opt + Hyper + x: 日本語翻訳を実行 [cite: 51]
    [:!QWERCc          ["open 'raycast://extensions/raycast/raycast-notes/raycast-notes'"]] ;; Hyper + c: Raycast Notes を開く [cite: 52]
   ]}

  ;; =======================================================================
  ;; カーソル・マウス操作 (Hyper Navigation) [cite: 53]
  ;; =======================================================================
  {:des "Hyper Navigation"
   :rules [
    ;; --- h (Left / Prev) --- [cite: 54]
    [:!QWERh          :left_arrow]                                       ;; Hyper + h: カーソルを左へ移動 [cite: 55]
    [:!QWERCh         :!Sleft_arrow]                                     ;; Cmd + Hyper + h: 左方向へテキスト選択 [cite: 56]
    [:!QWEROCh        :!SOleft_arrow]                                    ;; Opt + Cmd + Hyper + h: 左方向へ単語単位でテキスト選択 [cite: 57]
    [:!QWEROh         {:mouse_key {:x -1600}}]                           ;; Opt + Hyper + h: マウスカーソルを左へ移動 (中速) [cite: 60]
    [:!QWERSOh        {:mouse_key {:x -3200}}]                           ;; Shift + Opt + Hyper + h: マウスカーソルを左へ移動 (高速) [cite: 61]
    [:!QWERSTh        {:mouse_key {:horizontal_wheel 64}}]               ;; Shift + Ctrl + Hyper + h: マウスホイールを左へスクロール [cite: 62]
    [:!QWERSCh        {:mouse_key {:horizontal_wheel 128}}]              ;; Shift + Cmd + Hyper + h: マウスホイールを左へ高速スクロール [cite: 63]

    ;; --- j (Down / Focus) --- [cite: 64]
    [:!QWERj          :down_arrow]                                       ;; Hyper + j: カーソルを下へ移動 [cite: 65]
    [:!QWERCj         :!Sdown_arrow]                                     ;; Cmd + Hyper + j: 下方向へテキスト選択 [cite: 66]
    [:!QWEROCj        [[:!Sdown_arrow] [:!Sdown_arrow] [:!Sdown_arrow]]] ;; Opt + Cmd + Hyper + j: 下方向へ複数行まとめてテキスト選択 [cite: 67]
    [:!QWEROj         {:mouse_key {:y 1600}}]                            ;; Opt + Hyper + j: マウスカーソルを下へ移動 (中速) [cite: 70]
    [:!QWERSOj        {:mouse_key {:y 3200}}]                            ;; Shift + Opt + Hyper + j: マウスカーソルを下へ移動 (高速) [cite: 71]
    [:!QWERSTj        {:mouse_key {:vertical_wheel 64}}]                 ;; Shift + Ctrl + Hyper + j: マウスホイールを下へスクロール [cite: 72]
    [:!QWERSCj        {:mouse_key {:vertical_wheel 128}}]                ;; Shift + Cmd + Hyper + j: マウスホイールを下へ高速スクロール [cite: 73]

    ;; --- k (Up / Expose) --- [cite: 74]
    [:!QWERk          :up_arrow]                                         ;; Hyper + k: カーソルを上へ移動 [cite: 75]
    [:!QWERCk         :!Sup_arrow]                                       ;; Cmd + Hyper + k: 上方向へテキスト選択 [cite: 76]
    [:!QWEROCk        [[:!Sup_arrow] [:!Sup_arrow] [:!Sup_arrow]]]       ;; Opt + Cmd + Hyper + k: 上方向へ複数行まとめてテキスト選択 [cite: 77]
    [:!QWEROk         {:mouse_key {:y -1600}}]                           ;; Opt + Hyper + k: マウスカーソルを上へ移動 (中速) [cite: 80]
    [:!QWERSOk        {:mouse_key {:y -3200}}]                           ;; Shift + Opt + Hyper + k: マウスカーソルを上へ移動 (高速) [cite: 81]
    [:!QWERSTk        {:mouse_key {:vertical_wheel -64}}]                ;; Shift + Ctrl + Hyper + k: マウスホイールを上へスクロール [cite: 82]
    [:!QWERSCk        {:mouse_key {:vertical_wheel -128}}]               ;; Shift + Cmd + Hyper + k: マウスホイールを上へ高速スクロール [cite: 83]

    ;; --- l (Right / Next) --- [cite: 84]
    [:!QWERl          :right_arrow]                                      ;; Hyper + l: カーソルを右へ移動 [cite: 85]
    [:!QWERCl         :!Sright_arrow]                                    ;; Cmd + Hyper + l: 右方向へテキスト選択 [cite: 86]
    [:!QWEROCl        :!SOright_arrow]                                   ;; Opt + Cmd + Hyper + l: 右方向へ単語単位でテキスト選択 [cite: 87]
    [:!QWEROl         {:mouse_key {:x 1600}}]                            ;; Opt + Hyper + l: マウスカーソルを右へ移動 (中速) [cite: 90]
    [:!QWERSOl        {:mouse_key {:x 3200}}]                            ;; Shift + Opt + Hyper + l: マウスカーソルを右へ移動 (高速) [cite: 91]
    [:!QWERSTl        {:mouse_key {:horizontal_wheel -64}}]              ;; Shift + Ctrl + Hyper + l: マウスホイールを右へスクロール [cite: 92]
    [:!QWERSCl        {:mouse_key {:horizontal_wheel -128}}]             ;; Shift + Cmd + Hyper + l: マウスホイールを右へ高速スクロール [cite: 93]

    ;; --- u (Page Up / Zoom Out / Left Click) --- [cite: 94]
    [:!QWERu          :page_up]                                          ;; Hyper + u: ページアップ [cite: 95]
    [:!QWERCu         :!Spage_up]                                        ;; Cmd + Hyper + u: ページアップしつつ範囲選択 [cite: 96]
    [:!QWEROCu        :!Spage_up]                                        ;; Opt + Cmd + Hyper + u: ページアップしつつ範囲選択 [cite: 97]
    [:!QWEROu         [[:pointing_button] [:button1]]]                   ;; Opt + Hyper + u: マウス 左クリック [cite: 100]
    [:!QWERSOu        [[:pointing_button] [:button1]]]                   ;; Shift + Opt + Hyper + u: マウス 左クリック [cite: 101]
    [:!QWERSTu        {:mouse_key {:horizontal_wheel -64}}]              ;; Shift + Ctrl + Hyper + u: マウスホイール 右へスクロール [cite: 102]
    [:!QWERSCu        {:mouse_key {:horizontal_wheel -128}}]             ;; Shift + Cmd + Hyper + u: マウスホイール 右へ高速スクロール [cite: 103]

    ;; --- i (Home / Prev Window / Right Click) --- [cite: 104]
    [:!QWERi          :home]                                             ;; Hyper + i: 行頭へ移動 (Home) [cite: 105]
    [:!QWERCi         :!Shome]                                           ;; Cmd + Hyper + i: 行頭までテキスト選択 [cite: 106]
    [:!QWEROCi        [[:end] [:!Shome] [:!Shome]]]                       ;; Opt + Cmd + Hyper + i: 現在の行全体を選択 [cite: 107]
    [:!QWEROi         [[:pointing_button] [:button2]]]                   ;; Opt + Hyper + i: マウス 右クリック [cite: 110]
    [:!QWERSOi        [[:pointing_button] [:button2]]]                   ;; Shift + Opt + Hyper + i: マウス 右クリック [cite: 111]
    [:!QWERSTi        {:mouse_key {:vertical_wheel -64}}]                ;; Shift + Ctrl + Hyper + i: マウスホイール 上へスクロール [cite: 112]
    [:!QWERSCi        {:mouse_key {:vertical_wheel -128}}]               ;; Shift + Cmd + Hyper + i: マウスホイール 上へ高速スクロール [cite: 113]

    ;; --- o (End / Next Window / Backward) --- [cite: 114]
    [:!QWERo          :end]                                              ;; Hyper + o: 行末へ移動 (End) [cite: 115]
    [:!QWERCo         :!Send]                                            ;; Cmd + Hyper + o: 行末までテキスト選択 [cite: 116]
    [:!QWEROCo        [[:home] [:!Send]]]                                ;; Opt + Cmd + Hyper + o: 現在の行全体を選択 [cite: 117]
    [:!QWEROo         [[:pointing_button] [:button4]]]                   ;; Opt + Hyper + o: マウス サイドボタン4 (戻る) [cite: 120]
    [:!QWERSOo        [[:pointing_button] [:button4]]]                   ;; Shift + Opt + Hyper + o: マウス サイドボタン4 (戻る) [cite: 121]
    [:!QWERSTo        {:mouse_key {:vertical_wheel 64}}]                 ;; Shift + Ctrl + Hyper + o: マウスホイール 下へスクロール [cite: 122]
    [:!QWERSCo        {:mouse_key {:vertical_wheel 128}}]                ;; Shift + Cmd + Hyper + o: マウスホイール 下へ高速スクロール [cite: 123]

    ;; --- p (Page Down / Zoom In / LaunchPad / Forward) --- [cite: 124]
    [:!QWERp          :page_down]                                        ;; Hyper + p: ページダウン [cite: 125]
    [:!QWERCp         :!Spage_down]                                      ;; Cmd + Hyper + p: ページダウンしつつ範囲選択 [cite: 126]
    [:!QWEROCp        :!Spage_down]                                      ;; Opt + Cmd + Hyper + p: ページダウンしつつ範囲選択 [cite: 127]
    [:!QWERTp         ["open -a 'Launchpad'"]]                           ;; Ctrl + Hyper + p: Launchpad を開く [cite: 129]
    [:!QWEROp         [[:pointing_button] [:button5]]]                   ;; Opt + Hyper + p: マウス サイドボタン5 (進む) [cite: 130]
    [:!QWERSOp        [[:pointing_button] [:button5]]]                   ;; Shift + Opt + Hyper + p: マウス サイドボタン5 (進む) [cite: 131]
    [:!QWERSCp        {:mouse_key {:horizontal_wheel 128}}]              ;; Shift + Cmd + Hyper + p: マウスホイール 左へ高速スクロール [cite: 133]
   ]}

  ;; =======================================================================
  ;; 削除アクション (Hyper Deletion) [cite: 134]
  ;; =======================================================================
  {:des "Hyper Deletion"
   :rules [
    ;; --- option (O) + Hyper --- [cite: 135]
    [:!QWEROn         :!Cdelete_or_backspace]                            ;; Opt + Hyper + n: カーソルより前の行全体を削除 [cite: 136]
    [:!QWEROm         :!OSdown_arrow]                                    ;; Opt + Hyper + m: 現在の行を下へ移動 [cite: 137]
    [:!QWEROcomma     :!OSup_arrow]                                      ;; Opt + Hyper + ,: 現在の行を上へ移動 [cite: 138]
    [:!QWEROperiod    :!Cdelete_or_backspace]                            ;; Opt + Hyper + .: カーソルより前の行全体を削除 [cite: 139]

    ;; --- command (C) + Hyper --- [cite: 140]
    [:!QWERCn         [:!CSleft_arrow :delete_or_backspace]]             ;; Cmd + Hyper + n: カーソルより前を行全体削除 [cite: 141]
    [:!QWERCm         [:delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace :delete_or_backspace]] ;; Cmd + Hyper + m: 前の12文字分を連続削除 [cite: 141]                       
    [:!QWERCcomma     [:delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward :delete_forward]] ;; Cmd + Hyper + ,: 後の12文字分を連続削除 [cite: 141]                             
    [:!QWERCperiod    [:!CSright_arrow :delete_or_backspace]]            ;; Cmd + Hyper + .: カーソルより後を行全体削除 [cite: 142, 143]

    ;; --- Pure Hyper --- [cite: 143]
    [:!QWERn          :!Odelete_or_backspace]                            ;; Hyper + n: 前の単語を削除 [cite: 144]
    [:!QWERm          :delete_or_backspace]                              ;; Hyper + m: 前の文字を削除 (Backspace) [cite: 145]
    [:!QWERcomma      :delete_forward]                                   ;; Hyper + ,: 後の文字を削除 (Delete) [cite: 146]
    [:!QWERperiod     :!Odelete_forward]                                 ;; Hyper + .: 後の単語を削除 [cite: 147]
   ]}

  ;; =======================================================================
  ;; システム・メディアコントロール (Hyper Functional) [cite: 148]
  ;; =======================================================================
  {:des "Hyper Functional - Media & System Keys"
   :rules [
    [:!QWERf1         :display_brightness_decrement]                     ;; Hyper + F1: 画面の明るさを下げる [cite: 149]
    [:!QWERf2         :display_brightness_increment]                     ;; Hyper + F2: 画面の明るさを上げる [cite: 150]
    [:!QWERf3         :!Tup_arrow]                                       ;; Hyper + F3: Mission Control を開く [cite: 151]
    [:!QWERf4         :launchpad]                                        ;; Hyper + F4: Launchpad を開く [cite: 152]
    [:!QWERf5         :illumination_decrement]                           ;; Hyper + F5: キーボードバックライトを暗くする [cite: 153]
    [:!QWERf6         :illumination_increment]                           ;; Hyper + F6: キーボードバックライトを明るくする [cite: 154]
    [:!QWERf7         :rewind]                                           ;; Hyper + F7: メディア 巻き戻し [cite: 155]
    [:!QWERf8         :play_or_pause]                                    ;; Hyper + F8: メディア 再生/一時停止 [cite: 156]
    [:!QWERf9         :fast_forward]                                     ;; Hyper + F9: メディア 早送り [cite: 157]
    [:!QWERf10        :mute]                                             ;; Hyper + F10: 音量 ミュート [cite: 158]
    [:!QWERf11        :volume_decrement]                                 ;; Hyper + F11: 音量を下げる [cite: 159]
    [:!QWERf12        :volume_increment]                                 ;; Hyper + F12: 音量を上げる [cite: 160]
   ]}

  ;; =======================================================================
  ;; スクリーンショット (Screen Capture & Screenshots) [cite: 161]
  ;; =======================================================================
  {:des "Hyper Functional - Screen Capture & Screenshots"
   :rules [
    ;; --- ` (Grave Accent) --- [cite: 162]
    [:!QWERCgrave_accent_and_tilde :!CS4]                                ;; Cmd + Hyper + ~: 選択範囲のスクショをファイル保存 [cite: 163]
    [:!QWERgrave_accent_and_tilde  :!CTS4]                               ;; Hyper + ~: 選択範囲のスクショをクリップボード保存 [cite: 164]

    ;; --- F13 --- [cite: 165]
    [:!QWERCf13       :!CS3]                                             ;; Cmd + Hyper + F13: 画面全体のスクショをファイル保存 [cite: 166]
    [:!QWERf13        :!CTS3]                                            ;; Hyper + F13: 画面全体のスクショをクリップボード保存 [cite: 167]

    ;; --- F14 / F15 --- [cite: 168]
    [:!QWERCf14       :!CS6]                                             ;; Cmd + Hyper + F14: Touch Barのスクショを保存 [cite: 169]
    [:!QWERf14        :!CS5]                                             ;; Hyper + F14: 画面収録ツールを開く [cite: 170]
    [:!QWERf15        :play_or_pause]                                    ;; Hyper + F15: メディア 再生/一時停止 [cite: 171]
   ]}

  ;; =======================================================================
  ;; ウィンドウ・アプリ管理 (Hyper Window Management) [cite: 172]
  ;; =======================================================================
  {:des "Hyper Window Management"
   :rules [
                                   

    ;; --- Q キー操作 --- [cite: 176]
    [:!QWERq          :!Cq]                                              
    [:!QWERSq         ["osascript -e 'tell app \"System Events\" to restart'"]]
    [:!QWERSCq        ["osascript -e 'tell app \"System Events\" to shut down'"]]
    [:!QWERSOq        :!CSq]             

    ;; --- W キー操作 --- [cite: 179]
    [:!QWERw          :!Cw]              
    [:!QWERCw         :!CSt]             
    [:!QWERSw         :!CTq]             
    [:!QWERSCw        ["pmset sleepnow"]]

    ;; --- Tab キー操作 --- [cite: 183]
    [:!QWERtab         ["open -g 'raycast://extensions/raycast/window-management/maximize'"]]
    [:!QWERCtab        :!CTf] 
    [:!QWEROtab       :!Ch]  
    [:!QWERStab       :launchpad]
    [:!QWERSCtab       :!Tup_arrow]
    [:!QWERSOtab      :!Tdown_arrow]

    [:!QWERa        :!Copen_bracket]                                            
    [:!QWERs        :!Cclose_bracket]
    [:!QWERSa        :!Ctab]                                            
    [:!QWERSs        :!CStab]                                           
    [:!QWERTs        :!Tright_arrow]                                    
    [:!QWERTa        :!Tleft_arrow]  
    [:!QWERCa        :!Ttab]         
    [:!QWERCs        :!STtab]        
    [:!QWEROs        :!SOTbackslash] 
    [:!QWEROa        :!OTbackslash]  
    ]}

  ;; =======================================================================
  ;; 微調整コントロール (Navigation Key Controls Fine Tuning) [cite: 185]
  ;; =======================================================================
  {:des "Hyper Functional - Navigation Key Controls (Fine Tuning)"
   :rules [
    [:!QWERinsert         :!OSdisplay_brightness_increment]              ;; Hyper + Insert: 画面の明るさを微細に上げる [cite: 186, 187]
    [:!QWERdelete_forward :!OSdisplay_brightness_decrement]              ;; Hyper + ForwardDelete: 画面の明るさを微細に下げる [cite: 188]
    [:!QWERhome           :!OSillumination_increment]                    ;; Hyper + Home: キーボード輝度を微細に上げる [cite: 189]
    [:!QWERend            :!OSillumination_decrement]                    ;; Hyper + End: キーボード輝度を微細に下げる [cite: 190]
    [:!QWERpage_up        :!OSvolume_increment]                          ;; Hyper + PageUp: 音量を微細に上げる [cite: 191]
    [:!QWERpage_down      :!OSvolume_decrement]                          ;; Hyper + PageDown: 音量を微細に下げる [cite: 192]
   ]}

  ;; =======================================================================
  ;; Hyper Return & Symbols
  ;; =======================================================================
  {:des "Hyper Return & Symbols"
   :rules [
    [:!QWERSp              :grave_accent_and_tilde]

    [:!QWERopen_bracket   :!S9]
    [:!QWERSopen_bracket  :!Sopen_bracket]
    [:!QWERCopen_bracket  :!Scomma]
    [:!QWEROopen_bracket  :hyphen]
    [:!QWERTopen_bracket  :!Shyphen]

    [:!QWERclose_bracket  :!S9]
    [:!QWERSclose_bracket :!Sclose_bracket]
    [:!QWERCclose_bracket :!Speriod]
    [:!QWEROclose_bracket :equal_sign]
    [:!QWERTclose_bracket :!Sequal_sign]

    [:!QWERsemicolon      :return_or_enter]
    [:!QWERSsemicolon     :!Ssemicolon]
    [:!QWERCsemicolon     :!Creturn_or_enter]
    [:!QWEROsemicolon     :!Oreturn_or_enter]
    [:!QWERTsemicolon     :!Treturn_or_enter]

    [:!QWERquote          :return_or_enter]
    [:!QWERSquote         :!Squote]
    [:!QWERCquote         :!Creturn_or_enter]
    [:!QWEROquote         :!Oreturn_or_enter]
    [:!QWERTquote         :!Treturn_or_enter]

    [:!QWERslash          :!Cslash]
    [:!QWERCslash         :!S1]
    [:!QWEROslash         :!S3]
    [:!QWERTslash         :!S4]
    [:!QWERSslash         :!Sslash]
    [:!QWERSCslash        :!S8]
    [:!QWERSOslash        :!S7]
    [:!QWERSTslash        :!S6]
   ]}

  ;; =======================================================================
  ;; Raycast ウィンドウリサイズ (Raycast Window Management) [cite: 215, 216]
  ;; =======================================================================
  {:des "Raycast Window Management (original)"
   :rules [
    [:!QWERCTh        ["open -g 'raycast://extensions/raycast/window-management/left-half'"]]       ;; Cmd+Ctrl+Hyper+h: ウィンドウを左半分に配置 [cite: 217]
    [:!QWERCTl        ["open -g 'raycast://extensions/raycast/window-management/right-half'"]]      ;; Cmd+Ctrl+Hyper+l: ウィンドウを右半分に配置 [cite: 218]
    [:!QWERCTk        ["open -g 'raycast://extensions/raycast/window-management/top-half'"]]        ;; Cmd+Ctrl+Hyper+k: ウィンドウを上半分に配置 [cite: 219]
    [:!QWERCTj        ["open -g 'raycast://extensions/raycast/window-management/bottom-half'"]]     ;; Cmd+Ctrl+Hyper+j: ウィンドウを下半分に配置 [cite: 220]
    [:!QWERCTu        ["open -g 'raycast://extensions/raycast/window-management/almost-maximize"]]        ;; Cmd+Ctrl+Hyper+u: ウィンドウを最大化 [cite: 221]
    [:!QWERCTi        ["open -g 'raycast://extensions/raycast/window-management/make-larger'"]]     ;; Cmd+Ctrl+Hyper+i: ウィンドウを拡大 [cite: 222]
    [:!QWERCTo        ["open -g 'raycast://extensions/raycast/window-management/make-smaller'"]]    ;; Cmd+Ctrl+Hyper+o: ウィンドウを縮小 [cite: 223]
    [:!QWERCTp        ["open -g 'raycast://extensions/raycast/window-management/reasonable-size'"]] ;; Cmd+Ctrl+Hyper+p: ウィンドウを適度なサイズに配置 [cite: 224]
   ]}
 ]
}