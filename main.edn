{
 :simlayers {:delete-layer {:key :delete_or_backspace}}
 :input-sources {:greek {:input_source_id "com.apple.keylayout.Greek"}}

 :main [
  ;; =======================================================================
  ;; 基本修飾キー・レイヤー設定
  ;; =======================================================================
  {:des "SandS"
   :rules [
    [:##spacebar   :left_shift    nil {:alone :spacebar}]       ;; スペース単押しでスペース、他キー同時押しで左Shift（SandS） [cite: 1]
   ]}

  {:des "L-Command -> English / R-Command -> Japanese"
   :rules [
    [:left_command  :left_command  nil {:alone :japanese_eisuu}] ;; 左Command単押しで「英数」モードへ切り替え [cite: 1]
    [:right_command :right_command nil {:alone :japanese_kana}]  ;; 右Command単押しで「かな」モードへ切り替え [cite: 1]
   ]}

  {:des "L-Option -> Greek"
   :rules [
    [:left_option   :left_option   nil {:alone :greek}]          ;; 左Option単押しでギリシャ語キーボードへ切り替え [cite: 1]
   ]}

  {:des "Delete + F7-F12 for Media Keys"
   :rules [
    [:f7  :rewind           :delete-layer]                       ;; Delete + F7 で巻き戻し [cite: 1]
    [:f8  :play_or_pause    :delete-layer]                       ;; Delete + F8 で再生/一時停止 [cite: 1]
    [:f9  :fast_forward     :delete-layer]                       ;; Delete + F9 で早送り [cite: 1]
    [:f10 :mute             :delete-layer]                       ;; Delete + F10 でミュート [cite: 1]
    [:f11 :volume_decrement :delete-layer]                       ;; Delete + F11 で音量ダウン [cite: 1, 2]
    [:f12 :volume_increment :delete-layer]                       ;; Delete + F12 で音量アップ [cite: 2]
   ]}

  {:des "CapsLock to Hyper"
   :rules [
    [:##caps_lock   :!QWEright_shift nil {:alone :escape}]       ;; CapsLockをHyper化（Cmd+Opt+Ctrl+Shift）。単押しはEscape [cite: 2]
    [:!QWER#Pescape :caps_lock]                                  ;; Hyper + Escape で本来のCapsLockをトグル [cite: 2]
    [:!QWERspacebar :!Tspacebar]                                 ;; Hyper + Space で Ctrl + Space を送信 [cite: 2]
    [:!QWERCspacebar ["open 'raycast://extensions/raycast/emoji-symbols/search-emoji-symbols'"]] ;; Cmd + Hyper + Space で Raycast 絵文字検索を開く [cite: 2]
   ]}

  {:des "Fn to Ctrl"
   :rules [
    [:##fn :left_control]
   ]}


  ;; =======================================================================
  ;; アプリケーション起動・フォーカス (Hyper Application)
  ;; =======================================================================
  {:des "Hyper Application (original)"
   :rules [
    ;; ブラウザ・エディタ系
    [:!QWERe    ["open -a Arc"]]                                 ;; Hyper + e で Arcブラウザ を起動/切り替え [cite: 2]
    [:!QWERCe   ["open -a 'Google Chrome'"]]                     ;; Cmd + Hyper + e で Google Chrome を起動/切り替え [cite: 2]
    [:!QWEROe   ["open -a Safari"]]                              ;; Opt + Hyper + e で Safari を起動/切り替え [cite: 2]
    [:!QWERSe   ["open -a Cursor"]]                              ;; Shift + Hyper + e で Cursor を起動/切り替え [cite: 2]
    [:!QWERSCe  ["open -a 'Visual Studio Code'"]]                ;; Shift + Cmd + Hyper + e で VS Code を起動/切り替え [cite: 2]
    [:!QWERSOe  ["open -a Notes"]]                               ;; Shift + Opt + Hyper + e で メモ(Notes) を起動/切り替え [cite: 2]

    ;; ユーティリティ・ターミナル系
    [:!QWERr    ["open -a Finder"]]                              ;; Hyper + r で Finder を起動/切り替え [cite: 3]
    [:!QWERCr   ["open -a Preview"]]                             ;; Cmd + Hyper + r で プレビュー(Preview) を起動/切り替え [cite: 3]
    [:!QWERSr   ["open -a iTerm"]]                               ;; Shift + Hyper + r で iTerm を起動/切り替え [cite: 3]
    [:!QWERSCr  ["open -a Terminal"]]                            ;; Shift + Cmd + Hyper + r で ターミナル を起動/切り替え [cite: 3]

    ;; PIM (スケジュール・タスク・メール) 系
    [:!QWERy    ["open -a Reminders"]]                           ;; Hyper + y で リマインダー を起動/切り替え [cite: 3]
    [:!QWERCy   ["open -a Mail"]]                                ;; Cmd + Hyper + y で メール(Mail) を起動/切り替え [cite: 3]
    [:!QWEROy   ["open -a Calendar"]]                            ;; Opt + Hyper + y で カレンダー を起動/切り替え [cite: 3]

    ;; ドキュメント・ノート系
    [:!QWERCd   ["open -a Obsidian"]]                            ;; Cmd + Hyper + d で Obsidian を起動/切り替え [cite: 3]
    [:!QWERCb   ["open -a Bear"]]                                ;; Cmd + Hyper + b で Bear を起動/切り替え [cite: 3]
    [:!QWERCl   ["open -a Logseq"]]                              ;; Cmd + Hyper + l で Logseq を起動/切り替え [cite: 3]
    [:!QWERSCd  ["open -a Notion"]]                              ;; Shift + Cmd + Hyper + d で Notion を起動/切り替え [cite: 3]

    ;; ツール・システム系
    [:!QWERf    ["open -a Raycast"]]                             ;; Hyper + f で Raycast を起動/切り替え [cite: 3]
    [:!QWERCf   ["open -a 'Karabiner-Elements'"]]                ;; Cmd + Hyper + f で Karabiner-Elements を起動 [cite: 3]
    [:!QWEROf   ["open -a 'Karabiner-EventViewer'"]]             ;; Opt + Hyper + f で Karabiner-EventViewer を起動 [cite: 3, 4]
    [:!QWERSf   ["open -a 'Maccy'"]]                             ;; Shift + Hyper + f で クリップボード拡張(Maccy) を起動 [cite: 4]

    ;; AI系
    [:!QWERg    ["open -a Claude"]]                              ;; Hyper + g で Claude アプリを起動/切り替え [cite: 4]
    [:!QWERCg   ["open -a ChatGPT"]]                             ;; Cmd + Hyper + g で ChatGPT アプリを起動/切り替え [cite: 4]
    [:!QWEROg   ["open -a Gemini"]]                              ;; Opt + Hyper + g で Gemini アプリを起動/切り替え [cite: 4]
    [:!QWERSg   ["open -a Ollama"]]                              ;; Shift + Hyper + g で Ollama アプリを起動/切り替え [cite: 4]
    [:!QWERSCg  ["open -a 'LM Studio'"]]                         ;; Shift + Cmd + Hyper + g で LM Studio を起動/切り替え [cite: 4]

    ;; Raycast拡張機能系
    [:!QWERz    ["open 'raycast://extensions/raycast/raycast-ai/ai-chat'"]] ;; Hyper + z で Raycast AI チャットを開く [cite: 4]
    [:!QWERCz   ["open 'raycast://ai-commands/request-a-commentary'"]]       ;; Cmd + Hyper + z で AIに解説を要求 [cite: 4]
    [:!QWEROz   ["open 'raycast://ai-commands/summarize-3-points'"]]         ;; Opt + Hyper + z で AIに3ポイント要約を要求 [cite: 4]

    [:!QWERx    ["open 'raycast://extensions/mooxl/deepcast/index'"]]       ;; Hyper + x で Deepcast (翻訳) を開く [cite: 4]
    [:!QWERCx   ["open 'raycast://extensions/mooxl/deepcast/englishUS?arguments=%7B%22text%22%3A%22%22%7D'"]] ;; Cmd + Hyper + x で 英語(US)翻訳 [cite: 4]
    [:!QWEROx   ["open 'raycast://extensions/mooxl/deepcast/japanese?arguments=%7B%22text%22%3A%22%22%7D'"]]  ;; Opt + Hyper + x で 日本語翻訳 [cite: 4]

    [:!QWERc    ["open 'raycast://extensions/raycast/raycast-notes/raycast-notes'"]] ;; Hyper + c で Raycast Notes を開く [cite: 4]
    [:!QWERv    ["open 'raycast://extensions/raycast/apple-reminders/create-reminder'"]] ;; Hyper + v で Raycast リマインダー作成 [cite: 5]
   ]}

  ;; =======================================================================
  ;; カーソル・マウス操作 (Hyper Navigation)
  ;; =======================================================================
  {:des "Hyper Navigation"
   :rules [
    ;; --- h (Left / Prev) ---
    [:!QWERh    :left_arrow]                                     ;; Hyper + h で 左矢印 [cite: 6]
    [:!QWERCh   :!Sleft_arrow]                                   ;; Cmd + Hyper + h で 左を選択 (Shift + 左矢印) [cite: 6]
    [:!QWEROCh  :!SOleft_arrow]                                  ;; Opt + Cmd + Hyper + h で 単語単位で左を選択 [cite: 6]
    [:!QWERSh   :!TStab]                                         ;; Shift + Hyper + h で 前のタブへ (Ctrl + Shift + Tab) [cite: 6]
    [:!QWERTh   :!Tleft_arrow]                                   ;; Ctrl + Hyper + h で 左の操作スペースへ (Ctrl + 左矢印) [cite: 6]
    [:!QWEROh   {:mouse_key {:x -1600}}]                         ;; Opt + Hyper + h で マウスカーソルを左へ移動 (中速) [cite: 6]
    [:!QWERSOh  {:mouse_key {:x -3200}}]                         ;; Shift + Opt + Hyper + h で マウスカーソルを左へ移動 (高速) [cite: 6]
    [:!QWERSTh  {:mouse_key {:horizontal_wheel 64}}]             ;; Shift + Ctrl + Hyper + h で マウスホイールを左へスクロール [cite: 6]
    [:!QWERSCh  {:mouse_key {:horizontal_wheel 128}}]            ;; Shift + Cmd + Hyper + h で マウスホイールを左へ高速スクロール [cite: 6]

    ;; --- j (Down / Focus) ---
    [:!QWERj    :down_arrow]                                     ;; Hyper + j で 下矢印 [cite: 7]
    [:!QWERCj   :!Sdown_arrow]                                   ;; Cmd + Hyper + j で 下を選択 (Shift + 下矢印) [cite: 7]
    [:!QWEROCj  [[:!Sdown_arrow] [:!Sdown_arrow] [:!Sdown_arrow]]] ;; Opt + Cmd + Hyper + j で 下へ複数行まとめて選択 [cite: 7]
    [:!QWERSj   :!Ctab]                                          ;; Shift + Hyper + j で 次のタブへ (Ctrl + Tab) [cite: 7]
    [:!QWERTj   :!Tdown_arrow]                                   ;; Ctrl + Hyper + j で Expose/App Expose (Ctrl + 下矢印) [cite: 7]
    [:!QWEROj   {:mouse_key {:y 1600}}]                          ;; Opt + Hyper + j で マウスカーソルを下へ移動 (中速) [cite: 7]
    [:!QWERSOj  {:mouse_key {:y 3200}}]                          ;; Shift + Opt + Hyper + j で マウスカーソルを下へ移動 (高速) [cite: 7]
    [:!QWERSTj  {:mouse_key {:vertical_wheel 64}}]               ;; Shift + Ctrl + Hyper + j で マウスホイールを下へスクロール [cite: 7]
    [:!QWERSCj  {:mouse_key {:vertical_wheel 128}}]              ;; Shift + Cmd + Hyper + j で マウスホイールを下へ高速スクロール [cite: 7]

    ;; --- k (Up / Expose) ---
    [:!QWERk    :up_arrow]                                       ;; Hyper + k で 上矢印 [cite: 8]
    [:!QWERCk   :!Sup_arrow]                                     ;; Cmd + Hyper + k で 上を選択 (Shift + 上矢印) [cite: 8]
    [:!QWEROCk  [[:!Sup_arrow] [:!Sup_arrow] [:!Sup_arrow]]]     ;; Opt + Cmd + Hyper + k で 上へ複数行まとめて選択 [cite: 8]
    [:!QWERSk   :!CStab]                                         ;; Shift + Hyper + k で 前のタブへ (Ctrl + Shift + Tab) [cite: 8]
    [:!QWERTk   :!Tup_arrow]                                     ;; Ctrl + Hyper + k で Mission Control (Ctrl + 上矢印) [cite: 8]
    [:!QWEROk   {:mouse_key {:y -1600}}]                         ;; Opt + Hyper + k で マウスカーソルを上へ移動 (中速) [cite: 8]
    [:!QWERSOk  {:mouse_key {:y -3200}}]                         ;; Shift + Opt + Hyper + k で マウスカーソルを上へ移動 (高速) [cite: 8]
    [:!QWERSTk  {:mouse_key {:vertical_wheel -64}}]              ;; Shift + Ctrl + Hyper + k で マウスホイールを上へスクロール [cite: 8]
    [:!QWERSCk  {:mouse_key {:vertical_wheel -128}}]             ;; Shift + Cmd + Hyper + k で マウスホイールを上へ高速スクロール [cite: 8]

    ;; --- l (Right / Next) ---
    [:!QWERl    :right_arrow]                                    ;; Hyper + l で 右矢印 [cite: 9]
    [:!QWERCl   :!Sright_arrow]                                  ;; Cmd + Hyper + l で 右を選択 (Shift + 右矢印) [cite: 9]
    [:!QWEROCl  :!SOright_arrow]                                 ;; Opt + Cmd + Hyper + l で 単語単位で右を選択 [cite: 9]
    [:!QWERSl   :!Ttab]                                          ;; Shift + Hyper + l で 次のタブへ (Ctrl + Tab) [cite: 9]
    [:!QWERTl   :!Tright_arrow]                                  ;; Ctrl + Hyper + l で 右の操作スペースへ (Ctrl + 右矢印) [cite: 9]
    [:!QWEROl   {:mouse_key {:x 1600}}]                          ;; Opt + Hyper + l で マウスカーソルを右へ移動 (中速) [cite: 9]
    [:!QWERSOl  {:mouse_key {:x 3200}}]                          ;; Shift + Opt + Hyper + l で マウスカーソルを右へ移動 (高速) [cite: 9]
    [:!QWERSTl  {:mouse_key {:horizontal_wheel -64}}]            ;; Shift + Ctrl + Hyper + l で マウスホイールを右へスクロール [cite: 9]
    [:!QWERSCl  {:mouse_key {:horizontal_wheel -128}}]           ;; Shift + Cmd + Hyper + l で マウスホイールを右へ高速スクロール [cite: 9]

    ;; --- u (Page Up / Zoom Out / Left Click) ---
    [:!QWERu    :page_up]                                        ;; Hyper + u で Page Up [cite: 10]
    [:!QWERCu   :!Spage_up]                                      ;; Cmd + Hyper + u で Page Up 範囲選択 [cite: 10]
    [:!QWEROCu  :!Spage_up]                                      ;; Opt + Cmd + Hyper + u で Page Up 範囲選択 [cite: 10]
    [:!QWERSu   :!COhyphen]                                      ;; Shift + Hyper + u で ズームアウト (Cmd + Opt + -) [cite: 10]
    [:!QWERTu   :!CTf]                                           ;; Ctrl + Hyper + u で フルスクリーン切り替え (Ctrl + Cmd + F) [cite: 10]
    [:!QWEROu   [[:pointing_button] [:button1]]]                 ;; Opt + Hyper + u で 左クリック [cite: 10]
    [:!QWERSOu  [[:pointing_button] [:button1]]]                 ;; Shift + Opt + Hyper + u で 左クリック [cite: 10]
    [:!QWERSTu  {:mouse_key {:horizontal_wheel -64}}]            ;; Shift + Ctrl + Hyper + u で 右へスクロール [cite: 10]
    [:!QWERSCu  {:mouse_key {:horizontal_wheel -128}}]           ;; Shift + Cmd + Hyper + u で 右へ高速スクロール [cite: 10]

    ;; --- i (Home / Prev Window / Right Click) ---
    [:!QWERi    :home]                                           ;; Hyper + i で Home [cite: 11]
    [:!QWERCi   :!Shome]                                         ;; Cmd + Hyper + i で Home まで選択 [cite: 11]
    [:!QWEROCi  [[:end] [:!Shome] [:!Shome]]]                     ;; Opt + Cmd + Hyper + i で 行全体選択 [cite: 11]
    [:!QWERSi   :!CSgrave_accent_and_tilde]                      ;; Shift + Hyper + i で 前のウィンドウへ [cite: 11]
    [:!QWERTi   :!Ch]                                            ;; Ctrl + Hyper + i で ウィンドウを隠す (Cmd + h) [cite: 11]
    [:!QWEROi   [[:pointing_button] [:button2]]]                 ;; Opt + Hyper + i で 右クリック [cite: 11]
    [:!QWERSOi  [[:pointing_button] [:button2]]]                 ;; Shift + Opt + Hyper + i で 右クリック [cite: 11]
    [:!QWERSTi  {:mouse_key {:vertical_wheel -64}}]              ;; Shift + Ctrl + Hyper + i で 上へスクロール [cite: 11]
    [:!QWERSCi  {:mouse_key {:vertical_wheel -128}}]             ;; Shift + Cmd + Hyper + i で 上へ高速スクロール [cite: 11]

    ;; --- o (End / Next Window / Backward) ---
    [:!QWERo    :end]                                            ;; Hyper + o で End [cite: 12]
    [:!QWERCo   :!Send]                                          ;; Cmd + Hyper + o で End まで選択 [cite: 12]
    [:!QWEROCo  [[:home] [:!Send]]]                              ;; Opt + Cmd + Hyper + o で 行全体選択 [cite: 12]
    [:!QWERSo   :!Cgrave_accent_and_tilde]                       ;; Shift + Hyper + o で 次のウィンドウへ [cite: 12]
    [:!QWERTo   :!Tup_arrow]                                     ;; Ctrl + Hyper + o で Mission Control [cite: 12]
    [:!QWEROo   [[:pointing_button] [:button4]]]                 ;; Opt + Hyper + o で マウスボタン4 (戻る) [cite: 12]
    [:!QWERSOo  [[:pointing_button] [:button4]]]                 ;; Shift + Opt + Hyper + o で マウスボタン4 (戻る) [cite: 12]
    [:!QWERSTo  {:mouse_key {:vertical_wheel 64}}]               ;; Shift + Ctrl + Hyper + o で 下へスクロール [cite: 12]
    [:!QWERSCo  {:mouse_key {:vertical_wheel 128}}]              ;; Shift + Cmd + Hyper + o で 下へ高速スクロール [cite: 12]

    ;; --- p (Page Down / Zoom In / LaunchPad / Forward) ---
    [:!QWERp    :page_down]                                      ;; Hyper + p で Page Down [cite: 13]
    [:!QWERCp   :!Spage_down]                                    ;; Cmd + Hyper + p で Page Down 範囲選択 [cite: 13]
    [:!QWEROCp  :!Spage_down]                                    ;; Opt + Cmd + Hyper + p で Page Down 範囲選択 [cite: 13]
    [:!QWERSp   :!COequal_sign]                                  ;; Shift + Hyper + p で ズームイン [cite: 13]
    [:!QWERTp   ["open -a 'Launchpad'"]]                         ;; Ctrl + Hyper + p で Launchpad を開く [cite: 13]
    [:!QWEROp   [[:pointing_button] [:button5]]]                 ;; Opt + Hyper + p で マウスボタン5 (進む) [cite: 13]
    [:!QWERSOp  [[:pointing_button] [:button5]]]                 ;; Shift + Opt + Hyper + p で マウスボタン5 (進む) [cite: 13]
    [:!QWERSTp  {:mouse_key {:horizontal_wheel 64}}]             ;; Shift + Ctrl + Hyper + p で 左へスクロール [cite: 13]
    [:!QWERSCp  {:mouse_key {:horizontal_wheel 128}}]            ;; Shift + Cmd + Hyper + p で 左へ高速スクロール [cite: 13]

    ;; --- Return/Enter (Mouse Clicks) ---
    [:!QWERreturn_or_enter   [[:pointing_button] [:button1]]]    ;; Hyper + Return で 左クリック [cite: 14]
    [:!QWERSTreturn_or_enter [[:pointing_button] [:button1]]]    ;; Shift + Ctrl + Hyper + Return で 左クリック [cite: 14]
    [:!QWERCreturn_or_enter  [[:pointing_button] [:button2]]]    ;; Cmd + Hyper + Return で 右クリック [cite: 14]
    [:!QWEROreturn_or_enter  [[:pointing_button] [:button3]]]    ;; Opt + Hyper + Return で ミドルクリック [cite: 14]
    [:!QWERSreturn_or_enter  [[:pointing_button] [:button4]]]    ;; Shift + Hyper + Return で マウスボタン4 [cite: 14]
    [:!QWERTreturn_or_enter  [[:pointing_button] [:button5]]]    ;; Ctrl + Hyper + Return で マウスボタン5 [cite: 14]

    ;; --- Arrows (Mouse Wheel & Cursor Move) ---
    ;; Normal Wheel (Shift)
    [:!QWERSup_arrow     {:mouse_key {:vertical_wheel -64}}]     ;; Shift + Hyper + 上矢印 で 上スクロール [cite: 16]
    [:!QWERSdown_arrow   {:mouse_key {:vertical_wheel 64}}]      ;; Shift + Hyper + 下矢印 で 下スクロール [cite: 16]
    [:!QWERSleft_arrow   {:mouse_key {:horizontal_wheel 64}}]    ;; Shift + Hyper + 左矢印 で 左スクロール [cite: 16]
    [:!QWERSright_arrow  {:mouse_key {:horizontal_wheel -64}}]   ;; Shift + Hyper + 右矢印 で 右スクロール [cite: 16]

    ;; Slow Wheel (Shift + Option)
    [:!QWERSOup_arrow    {:mouse_key {:vertical_wheel -32}}]     ;; Shift + Opt + Hyper + 上矢印 で ゆっくり上スクロール [cite: 17]
    [:!QWERSOdown_arrow  {:mouse_key {:vertical_wheel 32}}]      ;; Shift + Opt + Hyper + 下矢印 で ゆっくり下スクロール [cite: 17]
    [:!QWERSOleft_arrow  {:mouse_key {:horizontal_wheel 32}}]    ;; Shift + Opt + Hyper + 左矢印 で ゆっくり左スクロール [cite: 17]
    [:!QWERSOright_arrow {:mouse_key {:horizontal_wheel -32}}]   ;; Shift + Opt + Hyper + 右矢印 で ゆっくり右スクロール [cite: 17]

    ;; Fast Wheel (Shift + Command) ※JSON指定通り数値を256/-256反映
    [:!QWERSCup_arrow    {:mouse_key {:vertical_wheel 256}}]     ;; Shift + Cmd + Hyper + 上矢印 で 高速下スクロール(※数値指定準拠) [cite: 18]
    [:!QWERSCdown_arrow  {:mouse_key {:vertical_wheel -256}}]    ;; Shift + Cmd + Hyper + 下矢印 で 高速上スクロール(※数値指定準拠) [cite: 18]
    [:!QWERSCleft_arrow  {:mouse_key {:horizontal_wheel 256}}]   ;; Shift + Cmd + Hyper + 左矢印 で 高速左スクロール [cite: 18]
    [:!QWERSCright_arrow {:mouse_key {:horizontal_wheel -256}}]  ;; Shift + Cmd + Hyper + 右矢印 で 高速右スクロール [cite: 18]

    ;; Slow Move (Option)
    [:!QWEROup_arrow     {:mouse_key {:y -800}}]                 ;; Opt + Hyper + 上矢印 で カーソルゆっくり上移動 [cite: 19]
    [:!QWEROdown_arrow   {:mouse_key {:y 800}}]                  ;; Opt + Hyper + 下矢印 で カーソルゆっくり下移動 [cite: 19]
    [:!QWEROleft_arrow   {:mouse_key {:x -800}}]                 ;; Opt + Hyper + 左矢印 で カーソルゆっくり左移動 [cite: 19]
    [:!QWEROright_arrow  {:mouse_key {:x 800}}]                  ;; Opt + Hyper + 右矢印 で カーソルゆっくり右移動 [cite: 19]

    ;; Fast Move (Command)
    [:!QWERCup_arrow     {:mouse_key {:y -4200}}]                ;; Cmd + Hyper + 上矢印 で カーソル高速上移動 [cite: 20]
    [:!QWERCdown_arrow   {:mouse_key {:y 4200}}]                 ;; Cmd + Hyper + 下矢印 で カーソル高速下移動 [cite: 20]
    [:!QWERCleft_arrow   {:mouse_key {:x -4200}}]                ;; Cmd + Hyper + 左矢印 で カーソル高速左移動 [cite: 20]
    [:!QWERCright_arrow  {:mouse_key {:x 4200}}]                 ;; Cmd + Hyper + 右矢印 で カーソル高速右移動 [cite: 20]

    ;; Normal Move (Hyper only)
    [:!QWERup_arrow      {:mouse_key {:y -1600}}]                ;; Hyper + 上矢印 で カーソル通常上移動 [cite: 21]
    [:!QWERdown_arrow    {:mouse_key {:y 1600}}]                 ;; Hyper + 下矢印 で カーソル通常下移動 [cite: 21]
    [:!QWERleft_arrow    {:mouse_key {:x -1600}}]                ;; Hyper + 左矢印 で カーソル通常左移動 [cite: 21]
    [:!QWERright_arrow   {:mouse_key {:x 1600}}]                 ;; Hyper + 右矢印 で カーソル通常右移動 [cite: 21]
   ]}

  ;; =======================================================================
  ;; 削除アクション (Hyper Deletion)
  ;; =======================================================================
  {:des "Hyper Deletion"
   :rules [
    ;; --- option (O) + Hyper ---
    [:!QWEROn     :!Cdelete_or_backspace]                        ;; Opt + Hyper + n で 行全体を削除 (Cmd + Backspace) [cite: 23]
    [:!QWEROm     :!OSdown_arrow]                                ;; Opt + Hyper + m で 行を下へ移動 (Opt + Shift + 下矢印) [cite: 24]
    [:!QWEROcomma :!OSup_arrow]                                  ;; Opt + Hyper + , で 行を上へ移動 (Opt + Shift + 上矢印) [cite: 25]
    [:!QWEROperiod :!Cdelete_or_backspace]                       ;; Opt + Hyper + . で 行全体を削除 (Cmd + Backspace) [cite: 26]

    ;; --- command (C) + Hyper ---
    [:!QWERCn     [:!CSleft_arrow :delete_or_backspace]]         ;; Cmd + Hyper + n で カーソルより前を行削除 [cite: 28]
    [:!QWERCm     :!Odelete_or_backspace]                        ;; Cmd + Hyper + m で 前の単語を削除 (Opt + Backspace) [cite: 29]
    [:!QWERCcomma :!Odelete_forward]                             ;; Cmd + Hyper + , で 後の単語を削除 (Opt + Delete) [cite: 30]
    [:!QWERCperiod [:!CSright_arrow :delete_or_backspace]]       ;; Cmd + Hyper + . で カーソルより後を行削除 [cite: 31]

    ;; --- Pure Hyper ---
    [:!QWERn      :!Odelete_or_backspace]                        ;; Hyper + n で 前の単語を削除 (Opt + Backspace) [cite: 32]
    [:!QWERm      :delete_or_backspace]                          ;; Hyper + m で 前の文字を削除 (Backspace) [cite: 33]
    [:!QWERcomma  :delete_forward]                               ;; Hyper + , で 後の文字を削除 (Delete) [cite: 34]
    [:!QWERperiod :!Odelete_forward]                             ;; Hyper + . で 後の単語を削除 (Opt + Delete) [cite: 35]
   ]}

  ;; =======================================================================
  ;; システム・メディアコントロール (Hyper Functional)
  ;; =======================================================================
  {:des "Hyper Functional - Media & System Keys"
   :rules [
    [:!QWERf1  :display_brightness_decrement]                    ;; Hyper + F1 で 画面の明るさを下げる [cite: 36]
    [:!QWERf2  :display_brightness_increment]                    ;; Hyper + F2 で 画面の明るさを上げる [cite: 36]
    [:!QWERf3  :!Tup_arrow]                                      ;; Hyper + F3 で Mission Control [cite: 36]
    [:!QWERf4  :launchpad]                                       ;; Hyper + F4 で Launchpad を開く [cite: 36]
    [:!QWERf5  :illumination_decrement]                          ;; Hyper + F5 で キーボードバックライトを下げる [cite: 36]
    [:!QWERf6  :illumination_increment]                          ;; Hyper + F6 で キーボードバックライトを上げる [cite: 36]
    [:!QWERf7  :rewind]                                          ;; Hyper + F7 で 巻き戻し [cite: 36]
    [:!QWERf8  :play_or_pause]                                   ;; Hyper + F8 で 再生/一時停止 [cite: 36]
    [:!QWERf9  :fast_forward]                                    ;; Hyper + F9 で 早送り [cite: 36]
    [:!QWERf10 :mute]                                            ;; Hyper + F10 で ミュート [cite: 36]
    [:!QWERf11 :volume_decrement]                                ;; Hyper + F11 で 音量を下げる [cite: 36]
    [:!QWERf12 :volume_increment]                                ;; Hyper + F12 で 音量を上げる [cite: 36]
   ]}

  ;; =======================================================================
  ;; スクリーンショット (Screen Capture & Screenshots)
  ;; =======================================================================
  {:des "Hyper Functional - Screen Capture & Screenshots"
   :rules [
    ;; --- ` (Grave Accent) ---
    [:!QWERCgrave_accent_and_tilde :!CS4]                        ;; Cmd + Hyper + ~ で 選択範囲のスクショをファイル保存 (Cmd+Shift+4) [cite: 37, 38]
    [:!QWERgrave_accent_and_tilde  :!CTS4]                       ;; Hyper + ~ で 選択範囲のスクショをクリップボード保存 (Cmd+Ctrl+Shift+4) [cite: 39]

    ;; --- F13 ---
    [:!QWERCf13 :!CS3]                                           ;; Cmd + Hyper + F13 で 画面全体のスクショをファイル保存 (Cmd+Shift+3) [cite: 40, 41]
    [:!QWERf13  :!CTS3]                                          ;; Hyper + F13 で 画面全体のスクショをクリップボード保存 (Cmd+Ctrl+Shift+3) [cite: 42]

    ;; --- F14 / F15 ---
    [:!QWERCf14 :!CS6]                                           ;; Cmd + Hyper + F14 で Touch Bar のスクショ (Cmd+Shift+6) [cite: 43, 44]
    [:!QWERf14  :!CS5]                                           ;; Hyper + F14 で 画面収録ツールを開く (Cmd+Shift+5) [cite: 45]
    [:!QWERf15  :play_or_pause]                                  ;; Hyper + F15 で 再生/一時停止 [cite: 45]
   ]}

  ;; =======================================================================
  ;; ウィンドウ・アプリ管理 (Hyper Window Management)
  ;; =======================================================================
  {:des "Hyper Window Management"
   :rules [
    ;; --- Tab キー操作 ---
    [:!QWERtab       :!Ctab]                                     ;; Hyper + Tab で アプリケーションの切り替え [cite: 50]
    [:!QWERStab      :!Ttab]                                     ;; Shift + Hyper + Tab で タブの切り替え (次のタブ) [cite: 46, 47]
    [:!QWEROtab      :!Tright_arrow]                             ;; Opt + Hyper + Tab で デスクトップ切り替え (右へ) [cite: 48]
    [:!QWERCtab      :!CStab]                                    ;; Cmd + Hyper + Tab で アプリケーション切り替え (逆順) [cite: 49]

    ;; --- Q キー操作 ---
    [:!QWERq         :!Cq]                                       ;; Hyper + q で アプリを終了 (Cmd + q) [cite: 54]
    [:!QWERTq        :!CTq]                                      ;; Ctrl + Hyper + q で 画面をロック [cite: 51]
    [:!QWERSq        :!CSq]                                      ;; Shift + Hyper + q で ログアウト [cite: 52]
    [:!QWERCq        :!Cq]                                       ;; Cmd + Hyper + q で アプリを強制終了 (Cmd + q 同様) [cite: 53]

    ;; --- W キー操作 ---
    [:!QWERw         :!Cw]                                       ;; Hyper + w で タブを閉じる (Cmd + w) [cite: 58]
    [:!QWERSw        ["pmset sleepnow"]]                         ;; Shift + Hyper + w で スリープ [cite: 55]
    [:!QWEROw        ["pmset displaysleepnow"]]                  ;; Opt + Hyper + w で ディスプレイスリープ [cite: 56]
    [:!QWERCw        :!Cw]                                       ;; Cmd + Hyper + w で 全てのタブを閉じる (アプリによる) [cite: 57]

    ;; --- A キー操作 ---
    [:!QWERTa        :launchpad]                    ;; Ctrl + Hyper + a で Launchpad を開く [cite: 59]
    [:!QWEROa        :f11]                                       ;; Opt + Hyper + a で デスクトップを表示 [cite: 60]
    [:!QWERCa        :!Cup_arrow]                                ;; Cmd + Hyper + a で 全ウィンドウ表示 (Expose All) [cite: 61]

    ;; --- S キー操作 ---
    [:!QWERs         :!Ttab]                                     ;; Hyper + s で タブシート切り替え [cite: 66]
    [:!QWERTs        :!CSgrave_accent_and_tilde]                 ;; Ctrl + Hyper + s で アプリ内ウィンドウ切り替え (逆順) [cite: 62, 63]
    [:!QWEROs        :!Cgrave_accent_and_tilde]                  ;; Opt + Hyper + s で アプリ内ウィンドウ切り替え [cite: 64]
    [:!QWERCs        :!CStab]                                    ;; Cmd + Hyper + s で タブシート切り替え (逆順) [cite: 65]
   ]}

  ;; =======================================================================
  ;; 微調整コントロール (Navigation Key Controls Fine Tuning)
  ;; =======================================================================
  {:des "Hyper Functional - Navigation Key Controls (Fine Tuning)"
   :rules [
    [:!QWERinsert         :!OSdisplay_brightness_increment]      ;; Hyper + Insert で 画面輝度を微細に上げる [cite: 67]
    [:!QWERdelete_forward :!OSdisplay_brightness_decrement]      ;; Hyper + ForwardDelete で 画面輝度を微細に下げる [cite: 68]
    [:!QWERhome           :!OSillumination_increment]            ;; Hyper + Home で キーボード輝度を微細に上げる [cite: 69]
    [:!QWERend            :!OSillumination_decrement]            ;; Hyper + End で キーボード輝度を微細に下げる [cite: 70]
    [:!QWERpage_up        :!OSvolume_increment]                  ;; Hyper + PageUp で 音量を微細に上げる [cite: 71]
    [:!QWERpage_down      :!OSvolume_decrement]                  ;; Hyper + PageDown で 音量を微細に下げる [cite: 72]
   ]}

  ;; =======================================================================
  ;; Return / Hyphen キー拡張 (Hyper Return)
  ;; =======================================================================
  {:des "Hyper Return (original)"
   :rules [
    ;; Quote キーを Return に割り当て
    [:!QWERquote      :return_or_enter]                          ;; Hyper + ' で Return を送信
    [:!QWERCquote     :!Creturn_or_enter]                        ;; Cmd + Hyper + ' で Cmd + Return を送信
    [:!QWERTquote     :!Treturn_or_enter]                        ;; Ctrl + Hyper + ' で Ctrl + Return を送信
    [:!QWERSquote     :!Sreturn_or_enter]                        ;; Shift + Hyper + ' で Shift + Return を送信
    [:!QWEROquote     :!Oreturn_or_enter]                        ;; Opt + Hyper + ' で Opt + Return を送信

    ;; Semicolon キーを Hyphen に割り当て
    [:!QWERsemicolon  :hyphen]                                   ;; Hyper + ; で ハイフン を送信
    [:!QWERCsemicolon :!Creturn_or_enter]                        ;; Cmd + Hyper + ; で Cmd + Return を送信
    [:!QWERTsemicolon :!Treturn_or_enter]                        ;; Ctrl + Hyper + ; で Ctrl + Return を送信
    [:!QWERSsemicolon :!Sreturn_or_enter]                        ;; Shift + Hyper + ; で Shift + Return を送信
    [:!QWEROsemicolon :!Oreturn_or_enter]                        ;; Opt + Hyper + ; で Opt + Return を送信
   ]}

  ;; =======================================================================
  ;; シンボル拡張 (Hyper Symbols)
  ;; =======================================================================
  {:des "Hyper Symbols (Original)"
   :rules [
    [:!QWERCslash  :!S1]                                         ;; Cmd + Hyper + / で ! (Shift + 1) を入力
    [:!QWERTslash  :!S2]                                         ;; Ctrl + Hyper + / で @ (Shift + 2) を入力
    [:!QWERSslash  :!S3]                                         ;; Shift + Hyper + / で # (Shift + 3) を入力
    [:!QWEROslash  :!S4]                                         ;; Opt + Hyper + / で $ (Shift + 4) を入力
    [:!QWERCTslash :!S5]                                         ;; Cmd + Ctrl + Hyper + / で % (Shift + 5) を入力 [cite: 73]
    [:!QWERCSslash :!S6]                                         ;; Cmd + Shift + Hyper + / で ^ (Shift + 6) を入力 [cite: 73]
    [:!QWERCOslash :!S7]                                         ;; Cmd + Opt + Hyper + / で & (Shift + 7) を入力 [cite: 73]
    [:!QWERTSslash :!S8]                                         ;; Ctrl + Shift + Hyper + / で * (Shift + 8) を入力 [cite: 73]
   ]}

  ;; =======================================================================
  ;; Raycast ウィンドウリサイズ (Raycast Window Management)
  ;; =======================================================================
  {:des "Raycast Window Management (original)"
   :rules [
    [:!QWERCTh       ["open -g 'raycast://extensions/raycast/window-management/left-half'"]]       ;; Cmd+Ctrl+Hyper+h で ウィンドウを左半分に配置
    [:!QWERCTl       ["open -g 'raycast://extensions/raycast/window-management/right-half'"]]      ;; Cmd+Ctrl+Hyper+l で ウィンドウを右半分に配置
    [:!QWERCTk       ["open -g 'raycast://extensions/raycast/window-management/top-half'"]]        ;; Cmd+Ctrl+Hyper+k で ウィンドウを上半分に配置
    [:!QWERCTj       ["open -g 'raycast://extensions/raycast/window-management/bottom-half'"]]     ;; Cmd+Ctrl+Hyper+j で ウィンドウを下半分に配置
    [:!QWERCTu       ["open -g 'raycast://extensions/raycast/window-management/maximize'"]]        ;; Cmd+Ctrl+Hyper+u で ウィンドウを最大化
    [:!QWERCTi       ["open -g 'raycast://extensions/raycast/window-management/make-larger'"]]     ;; Cmd+Ctrl+Hyper+i で ウィンドウを拡大
    [:!QWERCTo       ["open -g 'raycast://extensions/raycast/window-management/make-smaller'"]]    ;; Cmd+Ctrl+Hyper+o で ウィンドウを縮小
    [:!QWERCTp       ["open -g 'raycast://extensions/raycast/window-management/reasonable-size'"]] ;; Cmd+Ctrl+Hyper+p で ウィンドウを適度なサイズに
    [:!QWERCTspacebar ["open -g 'raycast://extensions/raycast/window-management/almost-maximize'"]] ;; Cmd+Ctrl+Hyper+Space で ウィンドウをほぼ最大化
   ]}
 ]
}