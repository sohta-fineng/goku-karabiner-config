{
    "description": "R-Option -> Numpad toggle",
    "manipulators": [
        {
            "conditions": [
                {
                    "name": "numpad_mode",
                    "type": "variable_unless",
                    "value": 1
                }
            ],
            "from": {
                "key_code": "right_option",
                "modifiers": { "optional": ["any"] }
            },
            "to": [{ "key_code": "right_option" }],
            "to_if_alone": [
                {
                    "set_variable": {
                        "name": "numpad_mode",
                        "value": 1
                    }
                },
                { "shell_command": "open -g 'raycast://script-commands/numpad-on'" }
            ],
            "type": "basic"
        },
        {
            "conditions": [
                {
                    "name": "numpad_mode",
                    "type": "variable_if",
